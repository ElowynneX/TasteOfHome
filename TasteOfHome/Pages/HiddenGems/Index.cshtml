@page
@model TasteOfHome.Pages.HiddenGems.IndexModel
@{
    ViewData["Title"] = "Hidden Gems";
}

<div class="hidden-page-wrapper">

    <div class="hidden-header">
        <div>
            <h2 class="hidden-title">Hidden Gems</h2>
            <p class="hidden-subtitle">
                Small home-based authentic food providers (family-run kitchens, couple-run services, home chefs, tiffin).
            </p>
        </div>

        <a asp-page="/HiddenGems/Submit" class="hidden-submit-btn">
            + Submit Hidden Gem
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="success-banner">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (!Model.HiddenGems.Any())
    {
        <div class="empty-state">
            No Hidden Gems yet.
        </div>
    }
    else
    {
        <div class="hidden-grid">
            @foreach (var h in Model.HiddenGems)
            {
                <div class="hidden-card">

                    <div class="hidden-card-top">
                        <h4>@h.ProviderName</h4>
                        <span class="hidden-auth">@h.AuthenticityHint%</span>
                    </div>

                    <p class="hidden-desc">@h.Description</p>

                    <div class="hidden-meta">
                        <div>
                            <i class="bi bi-geo-alt"></i> @h.Location
                        </div>
                        <span class="food-type">@h.FoodType</span>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(h.ContactInfo))
                    {
                        <div class="hidden-contact">
                            <strong>Contact:</strong> @h.ContactInfo
                        </div>
                    }

                    <div class="hidden-status @h.Status.ToLower()">
                        @h.Status
                    </div>

                </div>
            }
        </div>
    }

</div>