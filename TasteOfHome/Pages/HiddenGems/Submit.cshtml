@page
@model TasteOfHome.Pages.HiddenGems.SubmitModel
@{
    ViewData["Title"] = "Submit Hidden Gem";
}

<div class="submit-wrapper">

    <div class="submit-card">

        <div class="submit-header">
            <h2>Submit a Hidden Gem</h2>
            <p>
                Hidden Gems are small home-based food providers (family-run kitchens, couple-run services, home chefs, tiffin).
                They often have higher authenticity than restaurants.
            </p>
        </div>

        <form method="post" class="submit-form">

            <div asp-validation-summary="All" class="validation-box"></div>

            <div class="form-group-modern">
                <label asp-for="HiddenGem.ProviderName">Provider Name</label>
                <input asp-for="HiddenGem.ProviderName" />
                <span asp-validation-for="HiddenGem.ProviderName"></span>
            </div>

            <div class="form-group-modern">
                <label asp-for="HiddenGem.Location"></label>
                <input asp-for="HiddenGem.Location" />
                <span asp-validation-for="HiddenGem.Location"></span>
            </div>

            <div class="form-group-modern">
                <label asp-for="HiddenGem.FoodType">Food Type</label>
                <input asp-for="HiddenGem.FoodType" placeholder="e.g., Gujarati Tiffin / Punjabi Home Chef" />
                <span asp-validation-for="HiddenGem.FoodType"></span>
            </div>

            <div class="form-group-modern">
                <label asp-for="HiddenGem.Description"></label>
                <textarea asp-for="HiddenGem.Description" rows="4"></textarea>
                <span asp-validation-for="HiddenGem.Description"></span>
            </div>

            <div class="form-group-modern">
                <label asp-for="HiddenGem.ContactInfo">Contact / Order method (optional)</label>
                <input asp-for="HiddenGem.ContactInfo" placeholder="Phone / WhatsApp / Instagram / Email" />
                <span asp-validation-for="HiddenGem.ContactInfo"></span>
            </div>

            <div class="form-group-modern">
                <label asp-for="HiddenGem.AuthenticityHint">Authenticity (0–100)</label>
                <input asp-for="HiddenGem.AuthenticityHint" type="number" min="0" max="100" />
                <span asp-validation-for="HiddenGem.AuthenticityHint"></span>
            </div>

            <div class="submit-actions">
                <button type="submit" class="btn-submit-modern">
                    Submit Hidden Gem
                </button>

                <a href="/HiddenGems/Index" class="btn-back-modern">
                    Cancel
                </a>
            </div>

        </form>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}