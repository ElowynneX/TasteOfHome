@page
@model TasteOfHome.Pages.IndexModel
@{
    ViewData["Title"] = "Home";
}

<section class="home-hero">
    <div class="hero-inner">
        <h1 class="hero-title">TasteOfHome</h1>
        <div class="hero-underline"></div>
        <p class="hero-subtitle">
            Discover authentic restaurants by cuisine, culture, and dietary needs — all in one place.
        </p>
        <a asp-page="/Restaurants/Index" class="hero-btn">Browse Restaurants</a>
        <div class="hero-meta">Filter by cuisine • dietary preferences • culture</div>
    </div>
</section>

<style>
    .home-hero {
        padding: 64px 20px 56px;
        display: flex;
        justify-content: center;
        align-items: center;
        text-align: center;
        background: #f6f3f1;
    }

    .hero-inner {
        max-width: 760px;
        width: 100%;
    }

    .hero-title {
        font-size: clamp(3rem, 7vw, 4.5rem);
        font-weight: 900;
        color: #222;
        margin-bottom: 10px;
    }

    .hero-underline {
        width: 60px;
        height: 4px;
        border-radius: 999px;
        background: #ff6b2c;
        margin: 0 auto 20px;
    }

    .hero-subtitle {
        font-size: 1.35rem;
        color: #5c6678;
        line-height: 1.6;
        margin-bottom: 22px;
    }

    .hero-btn {
        display: inline-block;
        padding: 14px 28px;
        border-radius: 999px;
        background: linear-gradient(135deg, #ff8a00, #ff6b2c);
        color: white;
        font-weight: 700;
        text-decoration: none;
        box-shadow: 0 10px 24px rgba(255, 107, 44, 0.22);
    }

        .hero-btn:hover {
            color: white;
        }

    .hero-meta {
        margin-top: 14px;
        color: #8a93a3;
        font-size: 0.95rem;
    }
</style>