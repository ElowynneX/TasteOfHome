@page
@model IndexModel
@{
    ViewData["Title"] = "TasteOfHome";
}

<div class="home-hero">
    <div class="home-hero-inner">
        <h1 class="home-title">
            TasteOfHome
            <span class="title-accent"></span>
        </h1>

        <p class="home-subtitle">
            Discover authentic restaurants by cuisine, culture,
            and dietary needs — all in one place.
        </p>

        <div class="home-cta">
            <a class="btn btn-toh btn-lg" href="/Restaurants">
                Browse Restaurants
            </a>

            <p class="home-helper">
                Filter by cuisine • dietary preferences • culture
            </p>
        </div>
    </div>
</div>

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Approved Hidden Gems</h2>
        <a class="btn btn-success" href="/HiddenGems/Submit">+ Submit Hidden Gem</a>
    </div>

    @if (Model.ApprovedHiddenGems != null && Model.ApprovedHiddenGems.Any())
    {
        <div class="row">
            @foreach (var gem in Model.ApprovedHiddenGems)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title">@gem.ProviderName</h5>
                            <h6 class="card-subtitle mb-2 text-muted">@gem.FoodType</h6>
                            <p class="mb-2"><strong>Location:</strong> @gem.Location</p>
                            <p class="card-text">@gem.Description</p>
                            <p class="mb-2"><strong>Authenticity:</strong> @gem.AuthenticityHint%</p>

                            @if (!string.IsNullOrWhiteSpace(gem.ContactInfo))
                            {
                                <p class="mb-0"><strong>Contact:</strong> @gem.ContactInfo</p>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        <a class="btn btn-outline-primary" href="/HiddenGems/Index">View All Hidden Gems</a>
    }
    else
    {
        <div class="alert alert-info">
            No approved hidden gems yet.
        </div>
    }
</div>