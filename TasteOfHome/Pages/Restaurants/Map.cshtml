@page
@model TasteOfHome.Pages.Restaurants.MapModel
@using System.Text.Json
@{
    ViewData["Title"] = "Culture Explorer Map";

    var jsonOptions = new JsonSerializerOptions
    {
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase
    };

    var restaurantsJson = JsonSerializer.Serialize(Model.Restaurants, jsonOptions);
    var cuisineJson = JsonSerializer.Serialize(Model.CuisineGroups, jsonOptions);
    var cityJson = JsonSerializer.Serialize(Model.CityGroups, jsonOptions);
}

<div class="culture-map-page">
    <form id="mapAntiForgeryForm" style="display:none;">
        @Html.AntiForgeryToken()
    </form>

    <div class="container-fluid px-3 px-lg-4 py-4">
        <div class="map-page-header">
            <div>
                <div class="map-kicker">TasteOfHome Discovery</div>
                <h1 class="map-title">Culture Explorer Map</h1>
                <p class="map-subtitle">
                    Explore your curated TasteOfHome restaurants and live nearby restaurants across the visible map area.
                </p>
            </div>

            <div class="map-header-actions">
                <button type="button" class="map-outline-btn" id="resetFiltersBtn">
                    <i class="bi bi-arrow-counterclockwise"></i> Reset Filters
                </button>
                <a asp-page="/Restaurants/Index" class="map-outline-btn">
                    <i class="bi bi-grid"></i> List View
                </a>
            </div>
        </div>

        <div class="map-shell">
            <aside class="map-sidebar">
                <div class="sidebar-card sidebar-hero-card">
                    <div class="sidebar-badge">Interactive Map</div>
                    <h3>Find food by place and culture</h3>
                    <p>
                        Orange markers are your TasteOfHome restaurants. Blue markers are live nearby restaurants loaded from the current map area.
                    </p>

                    <div class="sidebar-stats">
                        <div class="sidebar-stat-box">
                            <div class="sidebar-stat-value" id="tohMappedCount">@Model.Restaurants.Count</div>
                            <div class="sidebar-stat-label">TasteOfHome shown</div>
                        </div>
                        <div class="sidebar-stat-box">
                            <div id="liveNearbyCount" class="sidebar-stat-value">0</div>
                            <div class="sidebar-stat-label">Nearby shown</div>
                        </div>
                    </div>
                </div>

                <div class="sidebar-card active-filter-card">
                    <div class="filter-title-row">
                        <h4>Active Filters</h4>
                    </div>
                    <div id="activeFilterSummary" class="active-filter-summary"></div>
                </div>

                <div class="sidebar-card legend-card">
                    <div class="filter-title-row">
                        <h4>Map Legend</h4>
                    </div>

                    <div class="legend-row">
                        <span class="legend-dot legend-dot-toh"></span>
                        <span>TasteOfHome restaurants</span>
                    </div>
                    <div class="legend-row">
                        <span class="legend-dot legend-dot-live"></span>
                        <span>Live nearby restaurants</span>
                    </div>
                </div>

                <div class="sidebar-card">
                    <div class="filter-title-row">
                        <h4>Cuisine</h4>
                        <button type="button" class="clear-filter-btn" id="clearCuisineBtn">Clear</button>
                    </div>
                    <div id="cuisineFilterBox" class="filter-chip-wrap"></div>
                </div>

                <div class="sidebar-card">
                    <div class="filter-title-row">
                        <h4>City</h4>
                        <button type="button" class="clear-filter-btn" id="clearCityBtn">Clear</button>
                    </div>
                    <div id="cityFilterBox" class="filter-chip-wrap"></div>
                </div>

                <div class="sidebar-card restaurant-results-card">
                    <div class="results-header">
                        <div>
                            <h4>TasteOfHome restaurants</h4>
                            <p id="resultsSummary">Loading map data...</p>
                        </div>
                    </div>

                    <div id="restaurantList" class="restaurant-list"></div>
                </div>
            </aside>

            <section class="map-stage-card">
                <div class="map-stage-topbar">
                    <div class="map-topbar-left">
                        <span class="map-topbar-pill map-topbar-pill-toh">TasteOfHome</span>
                        <span class="map-topbar-pill map-topbar-pill-live">Nearby</span>
                    </div>
                    <div class="map-topbar-right" id="mapViewportLabel">Live area discovery enabled</div>
                </div>

                <div id="cultureExplorerMap" class="culture-map"></div>
            </section>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster/dist/MarkerCluster.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster/dist/MarkerCluster.Default.css" />

    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
    <script src="https://unpkg.com/leaflet.markercluster/dist/leaflet.markercluster.js"></script>

    <script>
        const allRestaurants = @Html.Raw(restaurantsJson);
        const cuisineGroups = @Html.Raw(cuisineJson);
        const cityGroups = @Html.Raw(cityJson);

        let selectedCuisine = "all";
        let selectedCity = "all";

        let map;
        let tohMarkersLayer;
        let liveMarkersLayer;
        let liveLoadTimer = null;
        let livePlacesRaw = [];

        function escapeHtml(value) {
            if (!value) return "";
            return String(value)
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll('"', "&quot;")
                .replaceAll("'", "&#39;");
        }

        function normalizeCuisine(value) {
            if (!value) return "";
            return String(value)
                .toLowerCase()
                .replaceAll("_", " ")
                .replaceAll("-", " ")
                .replaceAll("restaurant", "")
                .trim();
        }

        function normalizeCity(value) {
            if (!value) return "";
            return String(value).toLowerCase().trim();
        }

        function createCuisineChips() {
            const box = document.getElementById("cuisineFilterBox");
            box.innerHTML = "";

            const allBtn = document.createElement("button");
            allBtn.type = "button";
            allBtn.className = "filter-chip active";
            allBtn.dataset.value = "all";
            allBtn.textContent = "All";
            allBtn.addEventListener("click", () => setCuisineFilter("all"));
            box.appendChild(allBtn);

            cuisineGroups.forEach(c => {
                const btn = document.createElement("button");
                btn.type = "button";
                btn.className = "filter-chip";
                btn.dataset.value = c;
                btn.textContent = c;
                btn.addEventListener("click", () => setCuisineFilter(c));
                box.appendChild(btn);
            });
        }

        function createCityChips() {
            const box = document.getElementById("cityFilterBox");
            box.innerHTML = "";

            const allBtn = document.createElement("button");
            allBtn.type = "button";
            allBtn.className = "filter-chip active";
            allBtn.dataset.value = "all";
            allBtn.textContent = "All";
            allBtn.addEventListener("click", () => setCityFilter("all"));
            box.appendChild(allBtn);

            cityGroups.forEach(c => {
                const btn = document.createElement("button");
                btn.type = "button";
                btn.className = "filter-chip";
                btn.dataset.value = c;
                btn.textContent = c;
                btn.addEventListener("click", () => setCityFilter(c));
                box.appendChild(btn);
            });
        }

        function setCuisineFilter(value) {
            selectedCuisine = value;
            updateFilterSelection("cuisineFilterBox", value);
            refreshAllLayers();
        }

        function setCityFilter(value) {
            selectedCity = value;
            updateFilterSelection("cityFilterBox", value);
            refreshAllLayers();
        }

        function clearCuisineFilter() {
            setCuisineFilter("all");
        }

        function clearCityFilter() {
            setCityFilter("all");
        }

        function resetAllFilters() {
            selectedCuisine = "all";
            selectedCity = "all";
            updateFilterSelection("cuisineFilterBox", "all");
            updateFilterSelection("cityFilterBox", "all");
            refreshAllLayers();
        }

        function updateFilterSelection(containerId, selectedValue) {
            document.querySelectorAll(`#${containerId} .filter-chip`).forEach(chip => {
                chip.classList.toggle("active", chip.dataset.value === selectedValue);
            });
        }

        function updateActiveFilterSummary() {
            const box = document.getElementById("activeFilterSummary");
            const cuisineText = selectedCuisine === "all" ? "All cuisines" : selectedCuisine;
            const cityText = selectedCity === "all" ? "All cities" : selectedCity;

            box.innerHTML = `
                <div class="active-filter-pill">
                    <span class="active-filter-label">Cuisine:</span> ${escapeHtml(cuisineText)}
                </div>
                <div class="active-filter-pill">
                    <span class="active-filter-label">City:</span> ${escapeHtml(cityText)}
                </div>
            `;
        }

        function getFilteredTohRestaurants() {
            return allRestaurants.filter(r => {
                const cuisineMatch =
                    selectedCuisine === "all" ||
                    normalizeCuisine(r.cuisine).includes(normalizeCuisine(selectedCuisine));

                const cityMatch =
                    selectedCity === "all" ||
                    normalizeCity(r.city).includes(normalizeCity(selectedCity)) ||
                    normalizeCity(r.location).includes(normalizeCity(selectedCity));

                return cuisineMatch && cityMatch;
            });
        }

        function getFilteredLivePlaces() {
            return livePlacesRaw.filter(p => {
                const cuisineSource = p.primaryType || "restaurant";
                const addressSource = p.address || "";

                const cuisineMatch =
                    selectedCuisine === "all" ||
                    normalizeCuisine(cuisineSource).includes(normalizeCuisine(selectedCuisine));

                const cityMatch =
                    selectedCity === "all" ||
                    normalizeCity(addressSource).includes(normalizeCity(selectedCity));

                return cuisineMatch && cityMatch;
            });
        }

        function cuisineColor(cuisine) {
            const key = (cuisine || "").toLowerCase();

            if (key.includes("indian")) return "#ff8a00";
            if (key.includes("chinese")) return "#ef4444";
            if (key.includes("italian")) return "#22c55e";
            if (key.includes("middle eastern")) return "#a855f7";
            if (key.includes("thai")) return "#f97316";
            if (key.includes("japanese")) return "#0ea5e9";
            if (key.includes("korean")) return "#ec4899";
            if (key.includes("mexican")) return "#84cc16";
            if (key.includes("ethiopian")) return "#f59e0b";
            if (key.includes("pakistani")) return "#14b8a6";
            if (key.includes("mediterranean")) return "#6366f1";
            return "#334155";
        }

        function buildTohPopupHtml(r) {
            const imageHtml = r.imageUrl
                ? `<img src="${escapeHtml(r.imageUrl)}" alt="${escapeHtml(r.name)}" class="popup-image" />`
                : `<div class="popup-image popup-image-fallback">TasteOfHome</div>`;

            const tags = (r.dietaryTags || []).slice(0, 3).map(tag =>
                `<span class="popup-tag">${escapeHtml(tag)}</span>`
            ).join("");

            return `
                <div class="popup-card popup-card-toh">
                    ${imageHtml}
                    <div class="popup-body">
                        <div class="popup-label popup-label-toh">TasteOfHome</div>
                        <div class="popup-title">${escapeHtml(r.name)}</div>
                        <div class="popup-subtitle">${escapeHtml(r.cuisine)} • ${escapeHtml(r.city || r.location)}</div>
                        <div class="popup-meta">⭐ ${Number(r.rating || 0).toFixed(1)} • ${escapeHtml(String(r.authenticity))}% authenticity</div>
                        <div class="popup-address">${escapeHtml(r.address || "")}</div>
                        ${tags ? `<div class="popup-tags">${tags}</div>` : ""}
                        <div class="popup-actions">
                            <a href="/Restaurants/Details?id=${r.id}" class="popup-link popup-link-secondary">View Details</a>
                            <a href="/Reservations/Create?restaurantId=${r.id}" class="popup-link popup-link-primary">Reserve Table</a>
                        </div>
                    </div>
                </div>
            `;
        }

        function buildLivePopupHtml(p) {
            const imageHtml = p.imageUrl
                ? `<img src="${escapeHtml(p.imageUrl)}" alt="${escapeHtml(p.name)}" class="popup-image" />`
                : `<div class="popup-image popup-image-fallback">Nearby Place</div>`;

            const payload = encodeURIComponent(JSON.stringify({
                name: p.name,
                address: p.address,
                primaryType: p.primaryType,
                latitude: p.latitude,
                longitude: p.longitude,
                rating: p.rating,
                imageUrl: p.imageUrl
            }));

            return `
                <div class="popup-card popup-card-live">
                    ${imageHtml}
                    <div class="popup-body">
                        <div class="popup-label popup-label-live">Nearby</div>
                        <div class="popup-title">${escapeHtml(p.name)}</div>
                        <div class="popup-subtitle">${escapeHtml(p.primaryType || "restaurant")}</div>
                        <div class="popup-meta">⭐ ${p.rating ? Number(p.rating).toFixed(1) : "N/A"}</div>
                        <div class="popup-address">${escapeHtml(p.address || "")}</div>
                        <div class="popup-actions">
                            <button type="button"
                                    class="popup-link popup-link-secondary"
                                    data-mode="details"
                                    data-place="${payload}">
                                View Details
                            </button>
                            <button type="button"
                                    class="popup-link popup-link-primary"
                                    data-mode="reserve"
                                    data-place="${payload}">
                                Reserve Table
                            </button>
                        </div>
                    </div>
                </div>
            `;
        }

        async function openImportedLivePlace(place, mode) {
            try {
                const token = document.querySelector('#mapAntiForgeryForm input[name="__RequestVerificationToken"]')?.value || "";

                const response = await fetch("/Restaurants/Map?handler=ImportLivePlace", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                        "RequestVerificationToken": token
                    },
                    body: JSON.stringify(place)
                });

                if (!response.ok) {
                    const errorText = await response.text();
                    console.error("ImportLivePlace failed:", response.status, errorText);
                    alert("Could not open this place right now.");
                    return;
                }

                const data = await response.json();

                if (!data.success) {
                    alert(data.message || "Could not import this place.");
                    return;
                }

                window.location.href = mode === "reserve" ? data.reserveUrl : data.detailsUrl;
            } catch (error) {
                console.error("openImportedLivePlace error:", error);
                alert("Something went wrong while opening this place.");
            }
        }

        function renderRestaurantList(restaurants) {
            const list = document.getElementById("restaurantList");
            const summary = document.getElementById("resultsSummary");

            summary.textContent = `${restaurants.length} restaurant${restaurants.length === 1 ? "" : "s"} shown`;
            document.getElementById("tohMappedCount").textContent = restaurants.length;

            if (!restaurants.length) {
                list.innerHTML = `
                    <div class="empty-state-box">
                        No TasteOfHome restaurants match the current filters.<br><br>
                        <button type="button" class="reset-empty-btn" id="resetEmptyFiltersBtn">Reset All Filters</button>
                    </div>
                `;
                return;
            }

            list.innerHTML = restaurants.map(r => {
                const tags = (r.dietaryTags || []).slice(0, 3).map(tag =>
                    `<span class="result-mini-tag">${escapeHtml(tag)}</span>`
                ).join("");

                return `
                    <button type="button" class="restaurant-list-card" data-restaurant-id="${r.id}">
                        <div class="restaurant-list-top">
                            <div>
                                <div class="restaurant-list-name">${escapeHtml(r.name)}</div>
                                <div class="restaurant-list-meta">${escapeHtml(r.cuisine)} • ${escapeHtml(r.city || r.location)}</div>
                            </div>
                            <div class="restaurant-list-rating">⭐ ${Number(r.rating || 0).toFixed(1)}</div>
                        </div>

                        <div class="restaurant-list-address">${escapeHtml(r.address || "")}</div>

                        <div class="restaurant-list-bottom">
                            <div class="restaurant-tags">${tags}</div>
                            <div class="restaurant-authenticity">${escapeHtml(String(r.authenticity))}% authentic</div>
                        </div>
                    </button>
                `;
            }).join("");
        }

        function renderTohMarkers(restaurants) {
            tohMarkersLayer.clearLayers();

            restaurants.forEach(r => {
                const marker = L.circleMarker([r.latitude, r.longitude], {
                    radius: 10,
                    fillColor: cuisineColor(r.cuisine),
                    color: "#ffffff",
                    weight: 3,
                    opacity: 1,
                    fillOpacity: 0.95
                });

                marker.restaurantId = r.id;

                marker.bindPopup(buildTohPopupHtml(r), {
                    maxWidth: 320,
                    className: "restaurant-popup-shell"
                });

                marker.on("mouseover", function () {
                    this.setStyle({ radius: 12, weight: 4 });
                });

                marker.on("mouseout", function () {
                    this.setStyle({ radius: 10, weight: 3 });
                });

                tohMarkersLayer.addLayer(marker);
            });
        }

        function renderLiveMarkers(places) {
            liveMarkersLayer.clearLayers();
            document.getElementById("liveNearbyCount").textContent = places.length;

            places.forEach(p => {
                const marker = L.circleMarker([p.latitude, p.longitude], {
                    radius: 7,
                    fillColor: "#2563eb",
                    color: "#ffffff",
                    weight: 2,
                    opacity: 1,
                    fillOpacity: 0.9
                });

                marker.bindPopup(buildLivePopupHtml(p), {
                    maxWidth: 320,
                    className: "restaurant-popup-shell"
                });

                liveMarkersLayer.addLayer(marker);
            });
        }

        function refreshAllLayers() {
            updateActiveFilterSummary();

            const filteredToh = getFilteredTohRestaurants();
            const filteredLive = getFilteredLivePlaces();

            renderRestaurantList(filteredToh);
            renderTohMarkers(filteredToh);
            renderLiveMarkers(filteredLive);
        }

        async function loadLiveNearbyPlaces() {
            const center = map.getCenter();
            const zoom = map.getZoom();

            let radius = 25000;
            if (zoom >= 14) radius = 4000;
            else if (zoom >= 13) radius = 6000;
            else if (zoom >= 12) radius = 10000;
            else if (zoom >= 11) radius = 15000;

            const label = document.getElementById("mapViewportLabel");
            label.textContent = "Loading nearby restaurants...";

            try {
                const response = await fetch(`/Restaurants/Map?handler=Nearby&lat=${center.lat}&lng=${center.lng}&radius=${radius}`);
                const data = await response.json();
                livePlacesRaw = data.places || [];
                refreshAllLayers();
                label.textContent = "Showing nearby places around the current map view";
            } catch (error) {
                console.error("Nearby load failed:", error);
                livePlacesRaw = [];
                refreshAllLayers();
                label.textContent = "Could not load nearby restaurants";
            }
        }

        function scheduleLiveReload() {
            if (liveLoadTimer) {
                clearTimeout(liveLoadTimer);
            }

            liveLoadTimer = setTimeout(() => {
                loadLiveNearbyPlaces();
            }, 500);
        }

        function focusTohRestaurant(id) {
            let found = null;

            tohMarkersLayer.eachLayer(layer => {
                if (layer.restaurantId === id) {
                    found = layer;
                }
            });

            if (found) {
                map.setView(found.getLatLng(), 15, { animate: true });
                found.openPopup();
            }
        }

        function fitInitialBounds() {
            const restaurants = getFilteredTohRestaurants();

            if (!restaurants.length) {
                map.setView([43.6532, -79.3832], 11);
                return;
            }

            const bounds = L.latLngBounds([]);
            restaurants.forEach(r => bounds.extend([r.latitude, r.longitude]));
            map.fitBounds(bounds, { padding: [40, 40] });
        }

        function wireDynamicEvents() {
            document.getElementById("clearCuisineBtn")?.addEventListener("click", clearCuisineFilter);
            document.getElementById("clearCityBtn")?.addEventListener("click", clearCityFilter);
            document.getElementById("resetFiltersBtn")?.addEventListener("click", resetAllFilters);

            document.addEventListener("click", function (e) {
                const restaurantButton = e.target.closest(".restaurant-list-card[data-restaurant-id]");
                if (restaurantButton) {
                    const id = parseInt(restaurantButton.dataset.restaurantId);
                    if (!isNaN(id)) {
                        focusTohRestaurant(id);
                    }
                    return;
                }

                const resetEmptyButton = e.target.closest("#resetEmptyFiltersBtn");
                if (resetEmptyButton) {
                    resetAllFilters();
                    return;
                }

                const liveActionButton = e.target.closest(".popup-card-live button[data-place][data-mode]");
                if (liveActionButton) {
                    const encoded = liveActionButton.getAttribute("data-place");
                    const mode = liveActionButton.getAttribute("data-mode");

                    try {
                        const place = JSON.parse(decodeURIComponent(encoded));
                        openImportedLivePlace(place, mode);
                    } catch (error) {
                        console.error("Failed to decode place payload:", error);
                        alert("Could not open this place.");
                    }
                }
            });
        }

        function initCultureMap() {
            map = L.map("cultureExplorerMap", {
                zoomControl: true,
                scrollWheelZoom: true
            }).setView([43.6532, -79.3832], 11);

            L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
                maxZoom: 19,
                attribution: "&copy; OpenStreetMap contributors"
            }).addTo(map);

            tohMarkersLayer = L.markerClusterGroup({
                showCoverageOnHover: false,
                spiderfyOnMaxZoom: true,
                zoomToBoundsOnClick: true,
                disableClusteringAtZoom: 15,
                iconCreateFunction: function (cluster) {
                    const count = cluster.getChildCount();
                    return L.divIcon({
                        html: `<div class="cluster-badge cluster-badge-toh">${count}</div>`,
                        className: "custom-cluster-icon",
                        iconSize: [42, 42]
                    });
                }
            });

            liveMarkersLayer = L.markerClusterGroup({
                showCoverageOnHover: false,
                spiderfyOnMaxZoom: true,
                zoomToBoundsOnClick: true,
                disableClusteringAtZoom: 15,
                iconCreateFunction: function (cluster) {
                    const count = cluster.getChildCount();
                    return L.divIcon({
                        html: `<div class="cluster-badge cluster-badge-live">${count}</div>`,
                        className: "custom-cluster-icon",
                        iconSize: [38, 38]
                    });
                }
            });

            map.addLayer(liveMarkersLayer);
            map.addLayer(tohMarkersLayer);

            createCuisineChips();
            createCityChips();
            wireDynamicEvents();
            refreshAllLayers();
            fitInitialBounds();
            loadLiveNearbyPlaces();

            map.on("moveend", scheduleLiveReload);
            map.on("zoomend", scheduleLiveReload);
        }

        document.addEventListener("DOMContentLoaded", initCultureMap);
    </script>
}

<style>
    .culture-map-page {
        background: linear-gradient(180deg, #f8f5f2 0%, #fcfbf9 100%);
        min-height: calc(100vh - 72px);
    }

    .map-page-header {
        display: flex;
        justify-content: space-between;
        align-items: end;
        gap: 20px;
        margin-bottom: 20px;
        flex-wrap: wrap;
    }

    .map-kicker {
        display: inline-flex;
        align-items: center;
        font-size: 0.78rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #ff7a2f;
        background: #fff1ea;
        padding: 8px 12px;
        border-radius: 999px;
        margin-bottom: 14px;
    }

    .map-title {
        font-size: clamp(2rem, 4.5vw, 3.2rem);
        font-weight: 900;
        color: #152033;
        margin-bottom: 8px;
    }

    .map-subtitle {
        color: #667085;
        font-size: 1.02rem;
        line-height: 1.7;
        margin-bottom: 0;
        max-width: 900px;
    }

    .map-header-actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }

    .map-outline-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 12px 16px;
        border-radius: 14px;
        text-decoration: none;
        font-weight: 700;
        color: #152033;
        background: white;
        border: 1px solid rgba(24, 39, 75, 0.12);
        box-shadow: 0 10px 20px rgba(18, 30, 48, 0.05);
    }

    .map-shell {
        display: grid;
        grid-template-columns: 390px 1fr;
        gap: 20px;
        align-items: start;
    }

    .map-sidebar {
        display: flex;
        flex-direction: column;
        gap: 16px;
        position: sticky;
        top: 88px;
        max-height: calc(100vh - 110px);
        overflow: auto;
        padding-right: 4px;
    }

    .sidebar-card,
    .map-stage-card {
        background: rgba(255,255,255,0.88);
        border: 1px solid rgba(24, 39, 75, 0.08);
        box-shadow: 0 16px 38px rgba(24, 39, 75, 0.08);
        border-radius: 24px;
    }

    .sidebar-card {
        padding: 18px;
    }

        .sidebar-hero-card h3,
        .sidebar-card h4 {
