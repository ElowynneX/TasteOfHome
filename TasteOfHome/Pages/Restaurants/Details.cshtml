@page
@model TasteOfHome.Pages.Restaurants.DetailsModel

@if (Model.Restaurant == null || Model.Restaurant.Id == 0)
{
    <div class="container py-5">
        <div class="alert alert-warning">Restaurant not found.</div>
        <a asp-page="/Restaurants/Index" class="btn btn-outline-secondary">Back to Restaurants</a>
    </div>
}
else
{
    <div class="container py-4">
        <div class="mb-3">
            <a asp-page="/Restaurants/Index" class="text-decoration-none fw-semibold">
                <i class="bi bi-arrow-left"></i> Back to Restaurants
            </a>
        </div>

        @if (TempData["StatusMessage"] != null)
        {
            <div class="alert alert-success">@TempData["StatusMessage"]</div>
        }

        <div class="card border-0 shadow-sm overflow-hidden mb-4">
            <div class="position-relative">
                <img src="@Model.RestaurantImageUrl"
                     alt="@Model.Restaurant.Name"
                     class="w-100"
                     style="height: 360px; object-fit: cover;"
                     loading="lazy"
                     onerror="this.src='/images/restaurants/default.jpg'" />

                <div class="position-absolute top-0 start-0 w-100 h-100"
                     style="background: linear-gradient(to top, rgba(0,0,0,0.72), rgba(0,0,0,0.18));">
                </div>

                <div class="position-absolute bottom-0 start-0 text-white p-4 w-100">
                    <div class="d-flex flex-wrap gap-2 mb-2">
                        <span class="badge bg-light text-dark px-3 py-2">@Model.Restaurant.Cuisine</span>
                        <span class="badge bg-warning text-dark px-3 py-2">@Model.PriceLevel</span>
                        <span class="badge bg-success px-3 py-2">
                            ⭐ @Model.Restaurant.Rating.ToString("0.0")
                        </span>
                        <span class="badge bg-primary px-3 py-2">
                            Authenticity @Model.Restaurant.Authenticity%
                        </span>
                    </div>

                    <h1 class="fw-bold mb-2">@Model.Restaurant.Name</h1>
                    <p class="mb-0 fs-6">
                        Authentic home-style @Model.Restaurant.Cuisine cuisine in @Model.Restaurant.Location
                    </p>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-4">
                        <h4 class="fw-bold mb-3">About this restaurant</h4>

                        <p class="text-muted mb-4">
                            Discover cultural flavors, community ratings, and signature dishes from
                            one of TasteOfHome’s featured restaurants.
                        </p>

                        <div class="row g-3">
                            <div class="col-md-4">
                                <div class="rounded-4 bg-light p-3 h-100 text-center">
                                    <div class="fs-4 fw-bold">@Model.Restaurant.Rating.ToString("0.0")</div>
                                    <div class="text-muted small">Average Rating</div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="rounded-4 bg-light p-3 h-100 text-center">
                                    <div class="fs-4 fw-bold">@Model.Restaurant.Authenticity%</div>
                                    <div class="text-muted small">Authenticity Score</div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="rounded-4 bg-light p-3 h-100 text-center">
                                    <div class="fs-4 fw-bold">@Model.Restaurant.NumberOfReviews</div>
                                    <div class="text-muted small">Approved Reviews</div>
                                </div>
                            </div>
                        </div>

                        <hr class="my-4" />

                        @if (User.Identity?.IsAuthenticated ?? false)
                        {
                            <a asp-page="/Restaurants/Feedback"
                               asp-route-id="@Model.Restaurant.Id"
                               class="btn btn-danger px-4">
                                Submit Authenticity Feedback
                            </a>
                        }
                        else
                        {
                            <a asp-page="/Login" class="btn btn-danger px-4">
                                Sign in to Leave Feedback
                            </a>
                        }
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-3">
                            <i class="bi bi-geo-alt me-2"></i>Location
                        </h5>

                        <p class="mb-2"><strong>City:</strong> @Model.Restaurant.Location</p>
                        <p class="mb-4"><strong>Address:</strong> @Model.Restaurant.Address</p>

                        <a href="https://www.google.com/maps/search/?api=1&query=@Uri.EscapeDataString(Model.Restaurant.Address)"
                           target="_blank"
                           rel="noopener noreferrer"
                           class="btn btn-outline-dark w-100">
                            Get Directions
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <span class="badge bg-success">Cultural Info</span>
                            <h4 class="fw-bold mb-0">Story & Heritage</h4>
                        </div>

                        @if (Model.HasCulturalStory)
                        {
                            <p class="mb-4">
                                @(string.IsNullOrWhiteSpace(Model.Restaurant.CulturalStory)
                                                        ? "Traditional family recipes and authentic food culture are at the heart of this restaurant."
                                                        : Model.Restaurant.CulturalStory)
                                                                                     </p>

                            <h6 class="fw-bold">Cultural Traditions</h6>
                            <p class="mb-0">
                                @(string.IsNullOrWhiteSpace(Model.Restaurant.CulturalTraditions)
                                                        ? "Authentic culinary traditions are preserved through ingredients, preparation, and service style."
                                                        : Model.Restaurant.CulturalTraditions)
                    </p>
                                        }
                        else
                        {
                            <p class="mb-0 text-muted">
                                Cultural story information is not available yet for this restaurant.
                            </p>
                        }
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <span class="badge bg-success">Dietary</span>
                            <h5 class="fw-bold mb-0">Options</h5>
                        </div>

                        @if (Model.HasDietaryTags)
                        {
                            <div class="d-flex flex-wrap gap-2">
                                @foreach (var tag in Model.Restaurant.DietaryTags)
                                {
                                    var badgeClass = "bg-secondary";

                                    if (tag.Equals("Vegetarian", StringComparison.OrdinalIgnoreCase))
                                    {
                                        badgeClass = "bg-success";
                                    }
                                    else if (tag.Equals("Vegan", StringComparison.OrdinalIgnoreCase))
                                    {
                                        badgeClass = "bg-dark";
                                    }
                                    else if (tag.Equals("Halal", StringComparison.OrdinalIgnoreCase))
                                    {
                                        badgeClass = "bg-primary";
                                    }
                                    else if (tag.Equals("Gluten-Free", StringComparison.OrdinalIgnoreCase))
                                    {
                                        badgeClass = "bg-warning text-dark";
                                    }

                                    <span class="badge @badgeClass px-3 py-2 rounded-pill">@tag</span>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-muted mb-0">No dietary options listed.</p>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <span class="badge bg-success">Featured</span>
                    <h4 class="fw-bold mb-0">Signature Dishes</h4>
                </div>

                @if (Model.HasSignatureDishes)
                {
                    <div class="row g-3">
                        @foreach (var dish in Model.Restaurant.SignatureDishes)
                        {
                            <div class="col-md-6 col-lg-3">
                                <div class="border rounded-4 p-3 h-100 bg-light">
                                    <div class="fw-semibold">@dish</div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted mb-0">No signature dishes listed.</p>
                }
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
                    <h4 class="fw-bold mb-0">Community Reviews</h4>

                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <a asp-page="/Restaurants/Feedback"
                           asp-route-id="@Model.Restaurant.Id"
                           class="btn btn-outline-danger btn-sm">
                            Write a Review
                        </a>
                    }
                </div>

                @if (Model.RestaurantFeedback != null && Model.RestaurantFeedback.Any())
                {
                    @foreach (var review in Model.RestaurantFeedback)
                    {
                        var isOwner = User.Identity?.IsAuthenticated == true &&
                        review.UserId == User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

                        <div class="border rounded-4 p-4 mb-3">
                            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-2">
                                <div>
                                    <div class="mb-2">
                                        @for (int i = 0; i < review.Rating; i++)
                                        {
                                            <span>⭐</span>
                                        }
                                    </div>

                                    <div class="text-muted small">
                                        Authenticity Score: <strong>@review.Authenticity%</strong>
                                    </div>

                                    @if (!string.IsNullOrWhiteSpace(review.Status) && review.Status != "Approved")
                                    {
                                        <div class="mt-2">
                                            <span class="badge bg-warning text-dark">@review.Status</span>
                                        </div>
                                    }
                                </div>
                            </div>

                            <p class="mb-0">@review.Review</p>

                            @if (isOwner)
                            {
                                <div class="mt-3">
                                    <a asp-page="/Reviews/Edit"
                                       asp-route-id="@review.Id"
                                       class="btn btn-warning btn-sm me-2">
                                        Edit
                                    </a>

                                    <form method="post"
                                          asp-page="/Reviews/Delete"
                                          style="display:inline;">
                                        <input type="hidden" name="id" value="@review.Id" />
                                        <button type="submit"
                                                class="btn btn-danger btn-sm"
                                                onclick="return confirm('Are you sure you want to delete this review?');">
                                            Delete
                                        </button>
                                    </form>
                                </div>
                            }
                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-4">
                        <p class="text-muted mb-3">No reviews yet — be the first to share your experience.</p>

                        @if (User.Identity?.IsAuthenticated ?? false)
                        {
                            <a asp-page="/Restaurants/Feedback"
                               asp-route-id="@Model.Restaurant.Id"
                               class="btn btn-danger">
                                Write First Review
                            </a>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
}