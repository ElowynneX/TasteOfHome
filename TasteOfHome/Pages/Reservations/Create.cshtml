@page "{restaurantId:int}"
@model TasteOfHome.Pages.Reservations.CreateModel
@{
    ViewData["Title"] = "Reserve a Table";

    var heroImage = !string.IsNullOrWhiteSpace(Model.RestaurantImageUrl)
        ? Model.RestaurantImageUrl
        : "/images/restaurants/default.svg";
}

<div class="container py-4">
    <a asp-page="/Restaurants/Details" asp-route-id="@Model.Restaurant.Id" class="text-decoration-none d-inline-block mb-3">
        ← Back to Restaurant
    </a>

    <div class="reservation-hero shadow-sm mb-4">
        <img src="@heroImage"
             alt="@Model.Restaurant.Name"
             onerror="this.onerror=null;this.src='/images/restaurants/default.svg';" />
        <div class="reservation-hero-overlay">
            <span class="hero-badge">Premium Reservation</span>
            <h1>Reserve a Table</h1>
            <h4>@Model.Restaurant.Name</h4>
            <p>@Model.Restaurant.Cuisine • @Model.Restaurant.Location</p>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h3 class="mb-4">Booking Details</h3>

                    <form method="post">
                        <input type="hidden" asp-for="Input.RestaurantId" />

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="Input.CustomerName" class="form-label"></label>
                                <input asp-for="Input.CustomerName" class="form-control form-control-lg rounded-3" />
                                <span asp-validation-for="Input.CustomerName" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Input.PhoneNumber" class="form-label"></label>
                                <input asp-for="Input.PhoneNumber" class="form-control form-control-lg rounded-3" placeholder="Phone number" />
                                <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Input.ReservationDate" class="form-label">Date</label>
                                <input asp-for="Input.ReservationDate" type="date" class="form-control form-control-lg rounded-3" />
                                <span asp-validation-for="Input.ReservationDate" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Input.ReservationTime" class="form-label">Time</label>
                                <select asp-for="Input.ReservationTime" class="form-select form-select-lg rounded-3">
                                    @foreach (var slot in Model.TimeSlots)
                                    {
                                        <option value="@slot">@slot</option>
                                    }
                                </select>
                                <span asp-validation-for="Input.ReservationTime" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Input.NumberOfGuests" class="form-label">Number of Guests</label>
                                <select asp-for="Input.NumberOfGuests" class="form-select form-select-lg rounded-3">
                                    @for (int i = 1; i <= Model.MaxGuestsAllowed; i++)
                                    {
                                        <option value="@i">@i</option>
                                    }
                                </select>
                                <span asp-validation-for="Input.NumberOfGuests" class="text-danger"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="Input.SpecialRequest" class="form-label">Special Request</label>
                                <textarea asp-for="Input.SpecialRequest"
                                          class="form-control rounded-3"
                                          rows="4"
                                          placeholder="Any dietary restrictions, seating request, or special occasion?"></textarea>
                                <span asp-validation-for="Input.SpecialRequest" class="text-danger"></span>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-lg w-100 rounded-4 mt-4 reserve-btn">
                            Confirm Reservation
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h3 class="mb-4">Restaurant Summary</h3>

                    <h5 class="mb-2">@Model.Restaurant.Name</h5>
                    <p class="text-muted mb-3">@Model.Restaurant.Address</p>

                    <div class="d-flex flex-wrap gap-2 mb-3">
                        <span class="summary-badge summary-badge-cuisine">@Model.Restaurant.Cuisine</span>
                        <span class="summary-badge summary-badge-rating">⭐ @Model.Restaurant.Rating.ToString("0.0")</span>
                        <span class="summary-badge summary-badge-auth">Authenticity @Model.Restaurant.Authenticity%</span>
                    </div>

                    <p class="text-muted mb-0">
                        Your saved settings can auto-fill guest count, phone number, dietary notes, and seating preference.
                        Reservations are saved with <strong>Pending</strong> status first to keep the experience realistic.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
    .reservation-hero {
        position: relative;
        overflow: hidden;
        border-radius: 24px;
        min-height: 280px;
        background: #111827;
    }

        .reservation-hero img {
            width: 100%;
            height: 280px;
            object-fit: cover;
            display: block;
        }

    .reservation-hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, rgba(0,0,0,0.15), rgba(0,0,0,0.65));
        color: white;
        padding: 20px;
        display: flex;
        flex-direction: column;
        justify-content: end;
    }

        .reservation-hero-overlay h1 {
            font-size: 3rem;
            font-weight: 800;
            margin-bottom: 8px;
        }

        .reservation-hero-overlay h4 {
            margin-bottom: 6px;
        }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        width: fit-content;
        background: #facc15;
        color: #111827;
        border-radius: 999px;
        padding: 6px 12px;
        font-weight: 700;
        font-size: 0.85rem;
        margin-bottom: 14px;
    }

    .reserve-btn {
        background: linear-gradient(135deg, #ff8a00, #ff4d6d);
        color: white;
        border: none;
    }

        .reserve-btn:hover {
            color: white;
            opacity: 0.95;
        }

    .summary-badge {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        padding: 6px 12px;
        font-size: 0.85rem;
        font-weight: 700;
    }

    .summary-badge-cuisine {
        background: #f3f4f6;
        color: #111827;
    }

    .summary-badge-rating {
        background: #16a34a;
        color: white;
    }

    .summary-badge-auth {
        background: #2563eb;
        color: white;
    }
</style>