@page
@model TasteOfHome.Pages.Reservations.MyReservationsModel
@{
    ViewData["Title"] = "My Reservations";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
        <div>
            <h2 class="fw-bold mb-1">My Reservations</h2>
            <p class="text-muted mb-0">Track your upcoming and past table bookings.</p>
        </div>

        <a asp-page="/Restaurants/Index" class="btn btn-outline-dark">
            Browse Restaurants
        </a>
    </div>
    @if (TempData["NotificationWarning"] != null)
    {
        <div class="alert alert-warning">@TempData["NotificationWarning"]</div>
    }
    @if (TempData["NotificationWarning"] != null)
    {
        <div class="alert alert-warning">@TempData["NotificationWarning"]</div>
    }
    @if (TempData["StatusMessage"] != null)
    {
        <div class="alert alert-success">@TempData["StatusMessage"]</div>
    }

    @if (Model.Reservations.Any())
    {
        <div class="row g-4">
            @foreach (var reservation in Model.Reservations)
            {
                var statusClass = "bg-secondary";
                if (reservation.Status == "Pending") statusClass = "bg-warning text-dark";
                if (reservation.Status == "Confirmed") statusClass = "bg-success";
                if (reservation.Status == "Cancelled") statusClass = "bg-danger";

                <div class="col-lg-6">
                    <div class="card border-0 shadow-sm rounded-4 h-100">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <h5 class="fw-bold mb-1">@reservation.Restaurant?.Name</h5>
                                    <div class="text-muted small">@reservation.Restaurant?.Location</div>
                                </div>

                                <span class="badge @statusClass px-3 py-2">@reservation.Status</span>
                            </div>

                            <div class="mb-2"><strong>Date:</strong> @reservation.ReservationDate.ToString("MMMM dd, yyyy")</div>
                            <div class="mb-2"><strong>Time:</strong> @reservation.ReservationTime</div>
                            <div class="mb-2"><strong>Guests:</strong> @reservation.NumberOfGuests</div>
                            <div class="mb-2"><strong>Phone:</strong> @reservation.PhoneNumber</div>

                            @if (!string.IsNullOrWhiteSpace(reservation.SpecialRequest))
                            {
                                <div class="mt-3">
                                    <strong>Special Request:</strong>
                                    <div class="text-muted">@reservation.SpecialRequest</div>
                                </div>
                            }

                            <div class="mt-4 d-flex gap-2 flex-wrap">
                                @if (reservation.RestaurantId > 0)
                                {
                                    <a asp-page="/Restaurants/Details"
                                       asp-route-id="@reservation.RestaurantId"
                                       class="btn btn-outline-dark btn-sm">
                                        View Restaurant
                                    </a>
                                }

                                @if (reservation.Status != "Cancelled")
                                {
                                    <form method="post" asp-page-handler="Cancel" class="d-inline">
                                        <input type="hidden" name="id" value="@reservation.Id" />
                                        <button type="submit"
                                                class="btn btn-outline-danger btn-sm"
                                                onclick="return confirm('Cancel this reservation?');">
                                            Cancel Reservation
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-5 text-center">
                <h4 class="fw-bold mb-2">No reservations yet</h4>
                <p class="text-muted mb-4">Reserve your first table and it will appear here.</p>
                <a asp-page="/Restaurants/Index" class="btn btn-dark">Find a Restaurant</a>
            </div>
        </div>
    }
</div>