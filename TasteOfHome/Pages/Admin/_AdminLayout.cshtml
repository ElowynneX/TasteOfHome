@using System.Security.Claims
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TasteOfHome Admin</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>
<body>
    @{
        var adminEmail = User.FindFirst(ClaimTypes.Email)?.Value ?? "";
        var currentPath = Context.Request.Path.Value ?? "";
    }

    <div class="admin-shell">
        <aside class="admin-sidebar">
            <div>
                <div class="admin-brand">
                    <div class="admin-brand-icon">🍴</div>
                    <div>
                        <div class="admin-brand-title">TasteOfHome</div>
                        <div class="admin-brand-subtitle">Admin Console</div>
                    </div>
                </div>

                <nav class="admin-nav">
                    <a class="admin-nav-link @(currentPath.StartsWith("/Admin") ? "active" : "")" asp-page="/Admin/Index">
                        <i class="bi bi-grid-1x2-fill"></i>
                        <span>Dashboard</span>
                    </a>

                    <a class="admin-nav-link" asp-page="/Index">
                        <i class="bi bi-house-door-fill"></i>
                        <span>Main Site</span>
                    </a>

                    <a class="admin-nav-link" asp-page="/Profile">
                        <i class="bi bi-person-circle"></i>
                        <span>Profile</span>
                    </a>

                    <a class="admin-nav-link" href="/logout">
                        <i class="bi bi-box-arrow-right"></i>
                        <span>Logout</span>
                    </a>
                </nav>
            </div>

            <div class="admin-sidebar-footer">
                <div class="admin-role-badge">Administrator</div>
                <div class="admin-email">@adminEmail</div>
            </div>
        </aside>

        <div class="admin-main">
            <header class="admin-topbar">
                <div>
                    <h1 class="admin-page-title">@ViewData["Title"]</h1>
                    <p class="admin-page-subtitle">Moderate reviews, manage hidden gems, and monitor platform activity.</p>
                </div>

                <div class="admin-topbar-right">
                    <span class="admin-status-dot"></span>
                    <span class="admin-status-text">Secure Admin Session</span>
                </div>
            </header>

            <main class="admin-content">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>