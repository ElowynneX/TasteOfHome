@page
@model TasteOfHome.Pages.Admin.Analytics.IndexModel
@{
    ViewData["Title"] = "Analytics";
}

<div class="analytics-page">
    <div class="analytics-header">
        <div>
            <h1 class="analytics-title">Platform Analytics</h1>
            <p class="analytics-subtitle">
                Premium admin insights for restaurants, hosted events, bookings, and platform activity.
            </p>
        </div>
        <div class="analytics-live-wrap">
            <div class="analytics-header-badge">
                <i class="bi bi-graph-up-arrow me-2"></i>Live Admin Insights
            </div>
            <div class="analytics-last-updated" id="lastUpdatedText">
                Last updated just now
            </div>
        </div>
    </div>

    <div class="analytics-stats-grid">
        <div class="analytics-stat-card">
            <div class="stat-icon green"><i class="bi bi-shop"></i></div>
            <div>
                <div class="stat-label">Restaurants</div>
                <div class="stat-value">@Model.TotalRestaurants</div>
            </div>
        </div>

        <div class="analytics-stat-card">
            <div class="stat-icon orange"><i class="bi bi-calendar-check-fill"></i></div>
            <div>
                <div class="stat-label">Restaurant Reservations</div>
                <div class="stat-value">@Model.TotalReservations</div>
            </div>
        </div>

        <div class="analytics-stat-card">
            <div class="stat-icon purple"><i class="bi bi-calendar-event-fill"></i></div>
            <div>
                <div class="stat-label">Hosted Events</div>
                <div class="stat-value">@Model.TotalEvents</div>
            </div>
        </div>

        <div class="analytics-stat-card">
            <div class="stat-icon pink"><i class="bi bi-ticket-perforated-fill"></i></div>
            <div>
                <div class="stat-label">Event Bookings</div>
                <div class="stat-value">@Model.TotalEventBookings</div>
            </div>
        </div>

        <div class="analytics-stat-card">
            <div class="stat-icon teal"><i class="bi bi-lightning-charge-fill"></i></div>
            <div>
                <div class="stat-label">Active Events</div>
                <div class="stat-value">@Model.ActiveEvents</div>
            </div>
        </div>

        <div class="analytics-stat-card">
            <div class="stat-icon red"><i class="bi bi-fire"></i></div>
            <div>
                <div class="stat-label">Sold Out Events</div>
                <div class="stat-value">@Model.SoldOutEvents</div>
            </div>
        </div>

        <div class="analytics-stat-card">
            <div class="stat-icon yellow"><i class="bi bi-hourglass-split"></i></div>
            <div>
                <div class="stat-label">Pending Hidden Gems</div>
                <div class="stat-value">@Model.PendingHiddenGems</div>
            </div>
        </div>

        <div class="analytics-stat-card">
            <div class="stat-icon blue"><i class="bi bi-cash-coin"></i></div>
            <div>
                <div class="stat-label">Event Revenue</div>
                <div class="stat-value">@Model.EventRevenue.ToString("C")</div>
            </div>
        </div>
    </div>

    <div class="charts-grid">
        <div class="chart-card chart-card-wide">
            <div class="panel-header">
                <h3>Top Cities by Reserved Spots</h3>
                <p>Bar chart of the strongest event cities.</p>
            </div>
            <div class="chart-wrap">
                <canvas id="citiesChart"></canvas>
            </div>
        </div>

        <div class="chart-card">
            <div class="panel-header">
                <h3>Event Status Mix</h3>
                <p>Distribution of active, sold out, and inactive events.</p>
            </div>
            <div class="chart-wrap donut-wrap">
                <canvas id="statusChart"></canvas>
            </div>
        </div>

        <div class="chart-card chart-card-wide">
            <div class="panel-header">
                <h3>Top Events by Bookings</h3>
                <p>Most-booked hosted events right now.</p>
            </div>
            <div class="chart-wrap">
                <canvas id="eventsChart"></canvas>
            </div>
        </div>
    </div>

    <div class="analytics-panels-grid">
        <div class="panel-card">
            <div class="panel-header">
                <h3>Top Cities by Event Activity</h3>
                <p>Best-performing locations by bookings and event count.</p>
            </div>

            @if (Model.TopCities.Any())
            {
                <div class="table-responsive">
                    <table class="table analytics-table mb-0">
                        <thead>
                            <tr>
                                <th>City</th>
                                <th>Events</th>
                                <th>Reserved Spots</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.TopCities)
                            {
                                <tr>
                                    <td>@item.City</td>
                                    <td>@item.EventCount</td>
                                    <td>@item.ReservedSpots</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="empty-panel">No city analytics available yet.</div>
            }
        </div>

        <div class="panel-card">
            <div class="panel-header">
                <h3>Top Events</h3>
                <p>Most booked hosted events on the platform.</p>
            </div>

            @if (Model.TopEvents.Any())
            {
                <div class="top-list">
                    @foreach (var item in Model.TopEvents)
                    {
                        var fillPercent = item.Capacity > 0
                        ? Math.Min(100, (int)Math.Round((double)item.ReservedSpots / item.Capacity * 100))
                        : 0;

                        <div class="top-list-item">
                            <div class="top-list-main">
                                <div>
                                    <div class="top-list-title">@item.Title</div>
                                    <div class="top-list-meta">@item.City • @item.ReservedSpots / @item.Capacity booked</div>
                                </div>
                                <div class="top-list-side">@item.Revenue.ToString("C")</div>
                            </div>
                            <div class="mini-progress">
                                <div class="mini-progress-fill" style="width:@fillPercent%;"></div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-panel">No event analytics available yet.</div>
            }
        </div>

        <div class="panel-card">
            <div class="panel-header">
                <h3>Restaurants Directory Snapshot</h3>
                <p>Quick overview of listed restaurants on the platform.</p>
            </div>

            @if (Model.TopRestaurants.Any())
            {
                <div class="table-responsive">
                    <table class="table analytics-table mb-0">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>City</th>
                                <th>Cuisine</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.TopRestaurants)
                            {
                                <tr>
                                    <td>@item.Name</td>
                                    <td>@item.City</td>
                                    <td>@item.Cuisine</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="empty-panel">No restaurant data available yet.</div>
            }
        </div>
    </div>
</div>

<style>
    .analytics-page {
        padding: 24px;
        color: #eef4ff;
    }

    .analytics-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        flex-wrap: wrap;
        margin-bottom: 24px;
    }

    .analytics-title {
        font-size: 2rem;
        font-weight: 800;
        color: #fff;
        margin-bottom: 6px;
    }

    .analytics-subtitle {
        margin: 0;
        color: #98acd2;
    }

    .analytics-live-wrap {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 6px;
    }

    .analytics-header-badge {
        background: rgba(255,255,255,0.08);
        color: #dfeaff;
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 999px;
        padding: 10px 16px;
        font-weight: 700;
    }

    .analytics-last-updated {
        color: #98acd2;
        font-size: 0.85rem;
    }

    .analytics-stats-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 18px;
        margin-bottom: 24px;
    }

    .analytics-stat-card {
        background: rgba(10, 21, 50, 0.92);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 22px;
        padding: 18px;
        display: flex;
        align-items: center;
        gap: 14px;
        box-shadow: 0 16px 34px rgba(0,0,0,0.2);
    }

    .stat-icon {
        width: 54px;
        height: 54px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1.25rem;
        flex-shrink: 0;
    }

    .blue {
        background: linear-gradient(135deg, #3b82f6, #1d4ed8);
    }

    .green {
        background: linear-gradient(135deg, #10b981, #047857);
    }

    .orange {
        background: linear-gradient(135deg, #f59e0b, #d97706);
    }

    .purple {
        background: linear-gradient(135deg, #8b5cf6, #6d28d9);
    }

    .pink {
        background: linear-gradient(135deg, #ec4899, #be185d);
    }

    .teal {
        background: linear-gradient(135deg, #14b8a6, #0f766e);
    }

    .red {
        background: linear-gradient(135deg, #ef4444, #b91c1c);
    }

    .yellow {
        background: linear-gradient(135deg, #facc15, #ca8a04);
    }

    .stat-label {
        color: #98acd2;
        font-size: 0.9rem;
        margin-bottom: 4px;
    }

    .stat-value {
        color: #fff;
        font-size: 1.55rem;
        font-weight: 800;
        line-height: 1.1;
    }

    .charts-grid {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 18px;
        margin-bottom: 24px;
    }

    .chart-card {
        background: rgba(10, 21, 50, 0.94);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 24px;
        padding: 20px;
        box-shadow: 0 18px 36px rgba(0,0,0,0.22);
    }

    .chart-card-wide {
        min-height: 360px;
    }

    .chart-wrap {
        position: relative;
        height: 280px;
    }

    .donut-wrap {
        height: 320px;
    }

    .analytics-panels-grid {
        display: grid;
        grid-template-columns: 1.1fr 1.2fr 1.1fr;
        gap: 18px;
    }

    .panel-card {
        background: rgba(10, 21, 50, 0.94);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 24px;
        padding: 20px;
        box-shadow: 0 18px 36px rgba(0,0,0,0.22);
        min-heightmin-height: 100%;
    }

    .panel-header h3 {
        color: #fff;
        font-size: 1.2rem;
        font-weight: 800;
        margin: 0 0 6px 0;
    }

    .panel-header p {
        color: #98acd2;
        margin: 0 0 16px 0;
        font-size: 0.92rem;
    }

    .analytics-table {
        color: #e7efff;
    }

        .analytics-table thead th {
            color: #8fa4cb;
            border-bottom-color: rgba(255,255,255,0.08);
            font-size: 0.82rem;
            text-transform: uppercase;
            letter-spacing: 0.04em;
        }

        .analytics-table tbody td {
            border-bottom-color: rgba(255,255,255,0.06);
            background: transparent;
            vertical-align: middle;
        }

    .top-list {
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .top-list-item {
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 18px;
        padding: 14px;
    }

    .top-list-main {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 8px;
    }

    .top-list-title {
        color: #fff;
        font-weight: 800;
    }

    .top-list-meta {
        color: #9eb0d0;
        font-size: 0.9rem;
    }

    .top-list-side {
        color: #7ef0c1;
        font-weight: 800;
        white-space: nowrap;
    }

    .mini-progress {
        width: 100%;
        height: 10px;
        background: rgba(255,255,255,0.08);
        border-radius: 999px;
        overflow: hidden;
    }

    .mini-progress-fill {
        height: 100%;
        border-radius: 999px;
        background: linear-gradient(90deg, #ff8a00, #ff4d6d);
    }

    .empty-panel {
        color: #9eb0d0;
        padding: 18px 0;
    }

    @@media (max-width: 1200px) {
        .analytics-stats-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .charts-grid,
        .analytics-panels-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 768px) {
        .analytics-page {
            padding: 16px;
        }

        .analytics-stats-grid {
            grid-template-columns: 1fr;
        }

        .analytics-title {
            font-size: 1.55rem;
        }

        .top-list-main {
            flex-direction: column;
        }

        .analytics-live-wrap {
            align-items: flex-start;
        }
    }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        const cityLabels = @Html.Raw(Model.CityChartLabelsJson);
        const cityData = @Html.Raw(Model.CityChartDataJson);
        const eventLabels = @Html.Raw(Model.EventChartLabelsJson);
        const eventData = @Html.Raw(Model.EventChartDataJson);
        const statusData = @Html.Raw(Model.StatusChartDataJson);

        new Chart(document.getElementById('citiesChart'), {
            type: 'bar',
            data: {
                labels: cityLabels,
                datasets: [{
                    label: 'Reserved Spots',
                    data: cityData,
                    backgroundColor: ['#3b82f6','#8b5cf6','#14b8a6','#f59e0b','#ec4899'],
                    borderRadius: 10,
                    borderSkipped: false
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { labels: { color: '#dbe7ff' } } },
                scales: {
                    x: { ticks: { color: '#9eb0d0' }, grid: { color: 'rgba(255,255,255,0.06)' } },
                    y: { beginAtZero: true, ticks: { color: '#9eb0d0' }, grid: { color: 'rgba(255,255,255,0.06)' } }
                }
            }
        });

        new Chart(document.getElementById('eventsChart'), {
            type: 'bar',
            data: {
                labels: eventLabels,
                datasets: [{
                    label: 'Bookings',
                    data: eventData,
                    backgroundColor: '#ff8a00',
                    borderRadius: 10,
                    borderSkipped: false
                }]
            },
            options: {
                indexAxis: 'y',
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { labels: { color: '#dbe7ff' } } },
                scales: {
                    x: { beginAtZero: true, ticks: { color: '#9eb0d0' }, grid: { color: 'rgba(255,255,255,0.06)' } },
                    y: { ticks: { color: '#9eb0d0' }, grid: { color: 'rgba(255,255,255,0.03)' } }
                }
            }
        });

        new Chart(document.getElementById('statusChart'), {
            type: 'doughnut',
            data: {
                labels: ['Active', 'Sold Out', 'Inactive'],
                datasets: [{
                    data: statusData,
                    backgroundColor: ['#10b981', '#ef4444', '#64748b'],
                    borderColor: '#0a1532',
                    borderWidth: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '68%',
                plugins: {
                    legend: { position: 'bottom', labels: { color: '#dbe7ff', padding: 16 } }
                }
            }
        });

        function updateLastUpdatedTime() {
            const el = document.getElementById('lastUpdatedText');
            if (!el) return;
            const now = new Date();
            el.textContent = `Last updated at ${now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}`;
        }

        updateLastUpdatedTime();
    </script>
}