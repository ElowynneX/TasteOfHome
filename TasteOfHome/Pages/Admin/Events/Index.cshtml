@page
@model TasteOfHome.Pages.Admin.Events.IndexModel
@{
    ViewData["Title"] = "Manage Events";
}

<div class="events-admin-page">
    <div class="events-admin-header">
        <div>
            <h1 class="events-admin-title">Manage Events</h1>
            <p class="events-admin-subtitle">
                Create, monitor, and manage hosted events with a more realistic admin dashboard view.
            </p>
        </div>

        <div class="events-admin-actions d-flex gap-2 flex-wrap">
            <a asp-page="/Admin/Events/CheckIn" class="btn-checkin-scanner">
                <i class="bi bi-qr-code-scan me-2"></i>Check-In Scanner
            </a>

            <a asp-page="/Admin/Events/Create" class="btn-create-event">
                <i class="bi bi-calendar2-plus me-2"></i>Create Event
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="events-alert-success">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
        </div>
    }

    <div class="events-stats-grid">
        <div class="stat-card">
            <div class="stat-icon stat-icon-blue">
                <i class="bi bi-calendar-event"></i>
            </div>
            <div>
                <div class="stat-label">Total Events</div>
                <div class="stat-value">@Model.TotalEvents</div>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon stat-icon-green">
                <i class="bi bi-check2-circle"></i>
            </div>
            <div>
                <div class="stat-label">Active Events</div>
                <div class="stat-value">@Model.ActiveEvents</div>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon stat-icon-orange">
                <i class="bi bi-fire"></i>
            </div>
            <div>
                <div class="stat-label">Sold Out</div>
                <div class="stat-value">@Model.SoldOutEvents</div>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon stat-icon-purple">
                <i class="bi bi-ticket-perforated"></i>
            </div>
            <div>
                <div class="stat-label">Total Reservations</div>
                <div class="stat-value">@Model.TotalBookings</div>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon stat-icon-teal">
                <i class="bi bi-person-check-fill"></i>
            </div>
            <div>
                <div class="stat-label">Checked-In Guests</div>
                <div class="stat-value">@Model.CheckedInGuests</div>
            </div>
        </div>

        <div class="stat-card stat-card-wide">
            <div class="stat-icon stat-icon-gold">
                <i class="bi bi-cash-coin"></i>
            </div>
            <div>
                <div class="stat-label">Revenue from Booked Spots</div>
                <div class="stat-value">@Model.TotalPotentialRevenue.ToString("C")</div>
            </div>
        </div>
    </div>

    <div class="events-table-card">
        <div class="events-table-header">
            <div>
                <h2>Hosted Events</h2>
                <p>Overview of all created events, booking progress, pricing, and live status.</p>
            </div>
        </div>

        @if (!Model.Events.Any())
        {
            <div class="empty-state">
                <div class="empty-state-icon">
                    <i class="bi bi-calendar-x"></i>
                </div>
                <h4>No events created yet</h4>
                <p>Your hosted events will appear here once you create them.</p>
                <a asp-page="/Admin/Events/Create" class="btn-create-event mt-2">
                    <i class="bi bi-plus-circle me-2"></i>Create First Event
                </a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table premium-events-table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Event</th>
                            <th>Date & Time</th>
                            <th>Location</th>
                            <th>Price</th>
                            <th>Capacity</th>
                            <th>Booking Progress</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Events)
                        {
                            var fillPercentage = item.Capacity > 0
                            ? Math.Min(100, (int)Math.Round((double)item.ReservedSpots / item.Capacity * 100))
                            : 0;

                            var soldOut = item.Capacity > 0 && item.ReservedSpots >= item.Capacity;
                            var upcoming = item.EventDate.Date >= DateTime.Today;
                            var statusClass = item.IsActive
                            ? (soldOut ? "badge-status-soldout" : "badge-status-active")
                            : "badge-status-inactive";

                            var statusText = item.IsActive
                            ? (soldOut ? "Sold Out" : "Active")
                            : "Inactive";

                            <tr>
                                <td>
                                    <div class="event-main-cell">
                                        <div class="event-thumb">
                                            @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                                            {
                                                <img src="@item.ImageUrl"
                                                     alt="@item.Title"
                                                     onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
                                                <div class="event-thumb-fallback" style="display:none;">
                                                    <i class="bi bi-image"></i>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="event-thumb-fallback">
                                                    <i class="bi bi-image"></i>
                                                </div>
                                            }
                                        </div>

                                        <div>
                                            <div class="event-title">@item.Title</div>
                                            <div class="event-meta">
                                                <span class="chip">@item.Category</span>
                                                <span class="chip">@item.CultureTag</span>
                                                @if (item.IsFeatured)
                                                {
                                                    <span class="chip chip-featured">Featured</span>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </td>

                                <td>
                                    <div class="fw-semibold">@item.EventDate.ToString("MMM dd, yyyy")</div>
                                    <div class="text-muted small">@item.StartTime - @item.EndTime</div>
                                    <div class="text-muted small">
                                        @(upcoming ? "Upcoming event" : "Past date")
                                    </div>
                                </td>

                                <td>
                                    <div class="fw-semibold">@item.City</div>
                                    <div class="text-muted small">@item.VenueName</div>
                                </td>

                                <td>
                                    <div class="price-pill">
                                        @item.PricePerPerson.ToString("C")
                                    </div>
                                </td>

                                <td>
                                    <div class="fw-semibold">@item.ReservedSpots / @item.Capacity</div>
                                    <div class="text-muted small">@item.AvailableSpots spot(s) left</div>
                                </td>

                                <td style="min-width: 180px;">
                                    <div class="progress-label-row">
                                        <span>@fillPercentage%</span>
                                        <span class="text-muted small">filled</span>
                                    </div>
                                    <div class="custom-progress">
                                        <div class="custom-progress-fill" style="width:@fillPercentage%;"></div>
                                    </div>
                                </td>

                                <td>
                                    <span class="badge-status @statusClass">@statusText</span>
                                </td>

                                <td class="text-end">
                                    <div class="action-buttons">
                                        <a asp-page="/Events/Reserve" asp-route-eventId="@item.Id" class="btn-action btn-view">
                                            View
                                        </a>
                                        <a asp-page="/Admin/Events/CheckIn" class="btn-action btn-checkin">
                                            Check-In
                                        </a>
                                        <a asp-page="/Admin/Events/Edit" asp-route-id="@item.Id" class="btn-action btn-edit">
                                            Edit
                                        </a>
                                        <form method="post" asp-page="/Admin/Events/Index" asp-page-handler="Delete"
                                              onsubmit="return confirm('Are you sure you want to delete this event?');"
                                              style="display:inline;">
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="btn-action btn-delete"
                                                    style="border:none; cursor:pointer;">
                                                Delete
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<style>
    .events-admin-page {
        padding: 24px;
        color: #eef4ff;
    }

    .events-admin-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        margin-bottom: 24px;
        flex-wrap: wrap;
    }

    .events-admin-title {
        font-size: 2rem;
        font-weight: 800;
        margin-bottom: 6px;
        color: #ffffff;
    }

    .events-admin-subtitle {
        margin: 0;
        color: #9db0d3;
        font-size: 0.98rem;
    }

    .btn-create-event {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #ff8a00, #ff4d6d);
        color: white;
        text-decoration: none;
        border: none;
        border-radius: 14px;
        padding: 12px 18px;
        font-weight: 700;
        box-shadow: 0 10px 24px rgba(255, 110, 77, 0.25);
        transition: all 0.2s ease;
    }

        .btn-create-event:hover {
            transform: translateY(-1px);
            color: white;
            box-shadow: 0 14px 28px rgba(255, 110, 77, 0.35);
        }

    .btn-checkin-scanner {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: rgba(59, 130, 246, 0.16);
        color: #9fc7ff;
        text-decoration: none;
        border: 1px solid rgba(59, 130, 246, 0.25);
        border-radius: 14px;
        padding: 12px 18px;
        font-weight: 700;
        transition: all 0.2s ease;
    }

        .btn-checkin-scanner:hover {
            transform: translateY(-1px);
            color: white;
            background: rgba(59, 130, 246, 0.28);
        }

    .events-alert-success {
        background: rgba(25, 135, 84, 0.16);
        border: 1px solid rgba(25, 135, 84, 0.35);
        color: #b8f5d2;
        border-radius: 14px;
        padding: 14px 16px;
        margin-bottom: 20px;
        font-weight: 600;
    }

    .events-stats-grid {
        display: grid;
        grid-template-columns: repeat(5, minmax(0, 1fr));
        gap: 18px;
        margin-bottom: 24px;
    }

    .stat-card,
    .stat-card-wide {
        background: rgba(10, 21, 50, 0.9);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 20px;
        padding: 18px;
        display: flex;
        align-items: center;
        gap: 14px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.18);
        backdrop-filter: blur(10px);
    }

    .stat-card-wide {
        grid-column: span 1;
    }

    .stat-icon {
        width: 54px;
        height: 54px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
        color: white;
        flex-shrink: 0;
    }

    .stat-icon-blue {
        background: linear-gradient(135deg, #3b82f6, #1d4ed8);
    }

    .stat-icon-green {
        background: linear-gradient(135deg, #10b981, #047857);
    }

    .stat-icon-orange {
        background: linear-gradient(135deg, #f59e0b, #d97706);
    }

    .stat-icon-purple {
        background: linear-gradient(135deg, #8b5cf6, #6d28d9);
    }

    .stat-icon-gold {
        background: linear-gradient(135deg, #f59e0b, #ef4444);
    }

    .stat-icon-teal {
        background: linear-gradient(135deg, #14b8a6, #0f766e);
    }

    .stat-label {
        color: #9db0d3;
        font-size: 0.9rem;
        margin-bottom: 4px;
    }

    .stat-value {
        font-size: 1.55rem;
        font-weight: 800;
        color: #ffffff;
        line-height: 1.1;
    }

    .events-table-card {
        background: rgba(10, 21, 50, 0.92);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 24px;
        padding: 20px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.22);
    }

    .events-table-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        margin-bottom: 18px;
        flex-wrap: wrap;
    }

        .events-table-header h2 {
            color: #ffffff;
            font-size: 1.35rem;
            font-weight: 800;
            margin: 0 0 4px 0;
        }

        .events-table-header p {
            margin: 0;
            color: #9db0d3;
        }

    .premium-events-table {
        background: transparent;
        color: #e8eefb;
        border-collapse: separate;
        border-spacing: 0 12px;
    }

        .premium-events-table thead th {
            border: none !important;
            color: #8fa4cb;
            font-size: 0.82rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            padding: 0 14px 8px 14px;
            background: transparent !important;
        }

        .premium-events-table tbody tr {
            background: rgba(255, 255, 255, 0.04);
            border-radius: 16px;
            overflow: hidden;
        }

        .premium-events-table tbody td {
            border-top: none !important;
            border-bottom: none !important;
            padding: 16px 14px;
            vertical-align: middle;
            background: rgba(255, 255, 255, 0.03);
        }

        .premium-events-table tbody tr td:first-child {
            border-top-left-radius: 16px;
            border-bottom-left-radius: 16px;
        }

        .premium-events-table tbody tr td:last-child {
            border-top-right-radius: 16px;
            border-bottom-right-radius: 16px;
        }

    .event-main-cell {
        display: flex;
        align-items: center;
        gap: 14px;
        min-width: 240px;
    }

    .event-thumb {
        width: 58px;
        height: 58px;
        border-radius: 14px;
        overflow: hidden;
        background: rgba(255,255,255,0.08);
        flex-shrink: 0;
        position: relative;
    }

        .event-thumb img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .event-thumb-fallback {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #ffb26b;
        font-size: 1.2rem;
        background: linear-gradient(135deg, rgba(255,138,0,0.18), rgba(255,77,109,0.15));
    }

    .event-title {
        font-weight: 800;
        color: #ffffff;
        margin-bottom: 6px;
    }

    .event-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }

    .chip {
        display: inline-flex;
        align-items: center;
        padding: 4px 9px;
        font-size: 0.75rem;
        border-radius: 999px;
        background: rgba(255,255,255,0.08);
        color: #d9e6ff;
        border: 1px solid rgba(255,255,255,0.08);
    }

    .chip-featured {
        background: rgba(255, 193, 7, 0.16);
        color: #ffd76a;
        border-color: rgba(255, 193, 7, 0.25);
    }

    .price-pill {
        display: inline-block;
        background: rgba(16, 185, 129, 0.15);
        color: #7ef0c1;
        padding: 7px 10px;
        border-radius: 999px;
        font-weight: 700;
        font-size: 0.9rem;
    }

    .progress-label-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 6px;
        color: #dce8ff;
        font-size: 0.85rem;
    }

    .custom-progress {
        width: 100%;
        height: 10px;
        background: rgba(255,255,255,0.08);
        border-radius: 999px;
        overflow: hidden;
    }

    .custom-progress-fill {
        height: 100%;
        border-radius: 999px;
        background: linear-gradient(90deg, #ff8a00, #ff4d6d);
    }

    .badge-status {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 7px 11px;
        border-radius: 999px;
        font-size: 0.78rem;
        font-weight: 700;
    }

    .badge-status-active {
        background: rgba(25, 135, 84, 0.18);
        color: #8cf0b8;
        border: 1px solid rgba(25, 135, 84, 0.28);
    }

    .badge-status-soldout {
        background: rgba(220, 53, 69, 0.18);
        color: #ff9eaa;
        border: 1px solid rgba(220, 53, 69, 0.28);
    }

    .badge-status-inactive {
        background: rgba(108, 117, 125, 0.18);
        color: #c8d0da;
        border: 1px solid rgba(108, 117, 125, 0.28);
    }

    .action-buttons {
        display: flex;
        justify-content: flex-end;
        gap: 8px;
        flex-wrap: wrap;
    }

    .btn-action {
        text-decoration: none;
        padding: 8px 12px;
        border-radius: 10px;
        font-size: 0.82rem;
        font-weight: 700;
        transition: all 0.2s ease;
    }

        .btn-action:hover {
            transform: translateY(-1px);
        }

    .btn-view {
        background: rgba(59, 130, 246, 0.16);
        color: #9fc7ff;
        border: 1px solid rgba(59, 130, 246, 0.25);
    }

    .btn-checkin {
        background: rgba(20, 184, 166, 0.16);
        color: #7ce7dc;
        border: 1px solid rgba(20, 184, 166, 0.25);
    }

    .btn-edit {
        background: rgba(255, 193, 7, 0.16);
        color: #ffd76a;
        border: 1px solid rgba(255, 193, 7, 0.25);
    }

    .btn-delete {
        background: rgba(220, 53, 69, 0.16);
        color: #ff9eaa;
        border: 1px solid rgba(220, 53, 69, 0.25);
    }

    .empty-state {
        text-align: center;
        padding: 46px 20px;
        color: #bfd0ec;
    }

    .empty-state-icon {
        width: 72px;
        height: 72px;
        border-radius: 20px;
        margin: 0 auto 16px auto;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255,255,255,0.06);
        font-size: 1.8rem;
        color: #ffb26b;
    }

    @@media (max-width: 1200px) {
        .events-stats-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 768px) {
        .events-admin-page {
            padding: 16px;
        }

        .events-stats-grid {
            grid-template-columns: 1fr;
        }

        .events-admin-title {
            font-size: 1.55rem;
        }

        .event-main-cell {
            min-width: unset;
        }
    }
</style>