        background: linear-gradient(135deg, #10b981, #047857);
        box-shadow: 0 12px 26px rgba(16,185,129,0.22);
    }

    .ticket-profile-card {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 14px;
        flex-wrap: wrap;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 20px;
        padding: 16px;
        margin-bottom: 18px;
    }

    .ticket-profile-main {
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .ticket-avatar {
        width: 58px;
        height: 58px;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #ff8a00, #ff4d6d);
        color: white;
        font-size: 1.3rem;
        font-weight: 800;
        flex-shrink: 0;
    }

    .ticket-guest-name {
        color: white;
        font-size: 1.12rem;
        font-weight: 800;
        margin-bottom: 3px;
    }

    .ticket-guest-meta {
        color: #b7c8e6;
        font-size: 0.92rem;
    }

    .ticket-amount-pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
