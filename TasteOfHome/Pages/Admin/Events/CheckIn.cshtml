    }

    .status-chip-danger {
        background: rgba(220, 53, 69, 0.18);
        color: #ff9eaa;
        border: 1px solid rgba(220, 53, 69, 0.28);
    }

    .status-chip-primary {
        background: rgba(13, 110, 253, 0.18);
        color: #b9d4ff;
        border: 1px solid rgba(13, 110, 253, 0.28);
    }

    .status-chip-muted {
        background: rgba(108, 117, 125, 0.18);
