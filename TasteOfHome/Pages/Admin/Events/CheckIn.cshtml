</style>

@section Scripts {
    <script src="https://unpkg.com/html5-qrcode"></script>
    <script>
        let scannerInstance = null;
        let scannerRunning = false;

        const ticketInput = document.getElementById("TicketCode");
        const scanStatusText = document.getElementById("scanStatusText");
        const cameraStatusBadge = document.getElementById("cameraStatusBadge");
        const scannerModeText = document.getElementById("scannerModeText");
        const validationText = document.getElementById("validationText");
        const startScannerBtn = document.getElementById("startScannerBtn");
        const stopScannerBtn = document.getElementById("stopScannerBtn");

        function setScannerUi(stateText, helperText, badgeText) {
            if (scannerModeText) scannerModeText.textContent = stateText;
            if (scanStatusText) scanStatusText.textContent = helperText;
            if (cameraStatusBadge) cameraStatusBadge.textContent = badgeText;
        }

        function setValidationText(text) {
            if (validationText) validationText.textContent = text;
        }

        function onScanSuccess(decodedText) {
            if (ticketInput) {
                ticketInput.value = decodedText;
                ticketInput.classList.add("border-success");
            }

            setScannerUi(
                "QR Detected",
                "QR scanned successfully. Review the ticket code below and click Lookup.",
                "QR Captured"
            );
            setValidationText("Ticket captured");
        }

        function onScanFailure() {
        }

        async function startScanner() {
            if (!window.Html5Qrcode || scannerRunning) return;

            try {
                scannerInstance = new Html5Qrcode("reader");
                await scannerInstance.start(
                    { facingMode: "environment" },
                    {
                        fps: 10,
                        qrbox: { width: 220, height: 220 }
                    },
                    onScanSuccess,
                    onScanFailure
                );

                scannerRunning = true;
                setScannerUi(
                    "Scanning Live",
                    "Camera is active. Hold the QR ticket steady inside the scan area.",
                    "Scanning"
                );
                setValidationText("Awaiting scan");
            } catch (err) {
                setScannerUi(
                    "Camera Error",
                    "Could not start the camera. You can still paste the ticket code manually.",
                    "Unavailable"
                );
                setValidationText("Manual lookup only");
                console.error(err);
            }
        }

        async function stopScanner() {
            if (!scannerInstance || !scannerRunning) return;

            try {
                await scannerInstance.stop();
                await scannerInstance.clear();
            } catch (err) {
                console.error(err);
            }

            scannerRunning = false;
            scannerInstance = null;

            setScannerUi(
                "Stopped",
                "Scanner stopped. Restart camera or use manual ticket lookup.",
                "Stopped"
            );
            setValidationText("Scanner paused");
        }

        if (startScannerBtn) {
            startScannerBtn.addEventListener("click", function () {
                startScanner();
            });
        }

        if (stopScannerBtn) {
            stopScannerBtn.addEventListener("click", function () {
                stopScanner();
            });
        }

        window.addEventListener("load", function () {
            startScanner();

            @if (Model.Reservation != null)
            {
                    if (Model.Reservation.IsCheckedIn)
                    {
                            <text>setValidationText("Already checked in");</text>
                    }
                    else if (Model.Reservation.Status == "Cancelled")
                    {
                            <text>setValidationText("Cancelled ticket");</text>
                    }
                    else if (Model.Reservation.PaymentStatus != "Paid")
                    {
                            <text>setValidationText("Payment pending");</text>
                    }
                    else
                    {
                            <text>setValidationText("Valid ticket loaded");</text>
                    }
            }
        });
    </script>
}