@page
@model TasteOfHome.Pages.Admin.Events.CheckInModel
@{
    ViewData["Title"] = "Event Check-In";
    Layout = "/Pages/Shared/_AdminLayout.cshtml";
}

<div class="checkin-page">
    <div class="checkin-header">
        <div>
            <h1 class="checkin-title">Event Ticket Check-In</h1>
            <p class="checkin-subtitle">
                Validate guest entry with QR scanning or manual ticket lookup.
            </p>
        </div>

        <div class="checkin-header-actions">
            <a asp-page="/Admin/Events/Index" class="btn-back-events">
                <i class="bi bi-arrow-left me-2"></i>Back to Events
            </a>
        </div>
    </div>

    @if (TempData["CheckInSuccess"] != null)
    {
        <div class="alert-success-modern">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["CheckInSuccess"]
        </div>
    }

    @if (TempData["CheckInError"] != null)
    {
        <div class="alert-danger-modern">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["CheckInError"]
        </div>
    }

    <div class="checkin-top-stats">
        <div class="mini-stat-card">
            <div class="mini-stat-icon blue">
                <i class="bi bi-qr-code-scan"></i>
            </div>
            <div>
                <div class="mini-stat-label">Scanner Mode</div>
                <div class="mini-stat-value" id="scannerModeText">Ready</div>
            </div>
        </div>

        <div class="mini-stat-card">
            <div class="mini-stat-icon green">
                <i class="bi bi-shield-check"></i>
            </div>
            <div>
                <div class="mini-stat-label">Validation</div>
                <div class="mini-stat-value" id="validationText">Awaiting ticket</div>
            </div>
        </div>

        <div class="mini-stat-card">
            <div class="mini-stat-icon orange">
                <i class="bi bi-person-badge"></i>
            </div>
            <div>
                <div class="mini-stat-label">Check-In Flow</div>
                <div class="mini-stat-value">Live Admin Control</div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-xl-6">
            <div class="glass-card h-100">
                <div class="card-head">
                    <div>
                        <h3 class="card-title">Scan Ticket</h3>
                        <p class="card-subtitle">Use camera scan or paste a ticket code manually.</p>
                    </div>
                    <span class="status-chip status-chip-blue" id="cameraStatusBadge">Camera Ready</span>
                </div>

                <div class="scanner-shell">
                    <div id="reader" class="scanner-box"></div>
                </div>

                <div class="scanner-helper" id="scanStatusText">
                    Point the camera at the guest's QR ticket. Best results on HTTPS or localhost.
                </div>

                <form method="post" asp-page-handler="Lookup" class="lookup-form">
                    <label class="form-label-modern">Ticket Code</label>
                    <div class="manual-entry-row">
                        <input asp-for="TicketCode"
                               id="TicketCode"
                               class="form-control modern-input"
                               placeholder="TOH-EVT-XXXXXXXXXXXX" />
                        <button type="submit" class="btn-lookup-ticket">
                            <i class="bi bi-search me-2"></i>Lookup
                        </button>
                    </div>
                </form>

                <div class="scanner-actions">
                    <button type="button" id="startScannerBtn" class="btn-soft-blue">
                        <i class="bi bi-camera-video me-2"></i>Start Scanner
                    </button>

                    <button type="button" id="stopScannerBtn" class="btn-soft-dark">
                        <i class="bi bi-stop-circle me-2"></i>Stop Scanner
                    </button>
                </div>
            </div>
        </div>

        <div class="col-xl-6">
            <div class="glass-card h-100">
                <div class="card-head">
                    <div>
                        <h3 class="card-title">Ticket Result</h3>
                        <p class="card-subtitle">Guest validation details and live entry control.</p>
                    </div>

                    @if (Model.Reservation == null)
                    {
                        <span class="status-chip status-chip-muted">No Ticket Loaded</span>
                    }
                    else if (Model.Reservation.IsCheckedIn)
                    {
                        <span class="status-chip status-chip-primary">Already Checked In</span>
                    }
                    else if (Model.Reservation.Status == "Cancelled")
                    {
                        <span class="status-chip status-chip-danger">Cancelled</span>
                    }
                    else if (Model.Reservation.PaymentStatus != "Paid")
                    {
                        <span class="status-chip status-chip-warning">Payment Pending</span>
                    }
                    else
                    {
                        <span class="status-chip status-chip-success">Valid Ticket</span>
                    }
                </div>

                @if (Model.Reservation == null)
                {
                    <div class="empty-ticket-state">
                        <div class="empty-ticket-icon">
                            <i class="bi bi-ticket-perforated"></i>
                        </div>
                        <h4>No ticket selected yet</h4>
                        <p>Scan a QR code or paste a ticket code to load guest details and allow check-in.</p>
                    </div>
                }
                else
                {
                    <div class="ticket-profile-card">
                        <div class="ticket-profile-main">
                            <div class="ticket-avatar">
                                @Model.Reservation.CustomerName.Substring(0, 1).ToUpper()
                            </div>

                            <div>
                                <div class="ticket-guest-name">@Model.Reservation.CustomerName</div>
                                <div class="ticket-guest-meta">@Model.Reservation.Email</div>
                                <div class="ticket-guest-meta">@Model.Reservation.PhoneNumber</div>
                            </div>
                        </div>

                        <div class="ticket-amount-pill">
                            @Model.Reservation.AmountPaid.ToString("C")
                        </div>
                    </div>

                    <div class="ticket-grid">
                        <div class="ticket-info-card">
                            <div class="ticket-info-label">Event</div>
                            <div class="ticket-info-value">@Model.Reservation.CulturalEvent?.Title</div>
                        </div>

                        <div class="ticket-info-card">
                            <div class="ticket-info-label">Date</div>
                            <div class="ticket-info-value">@Model.Reservation.CulturalEvent?.EventDate.ToString("MMMM dd, yyyy")</div>
                        </div>

                        <div class="ticket-info-card">
                            <div class="ticket-info-label">Venue</div>
                            <div class="ticket-info-value">@Model.Reservation.CulturalEvent?.VenueName</div>
                        </div>

                        <div class="ticket-info-card">
                            <div class="ticket-info-label">Spots</div>
                            <div class="ticket-info-value">@Model.Reservation.NumberOfSpots</div>
                        </div>

                        <div class="ticket-info-card">
                            <div class="ticket-info-label">Payment</div>
                            <div class="ticket-info-value">@Model.Reservation.PaymentStatus</div>
                        </div>

                        <div class="ticket-info-card">
                            <div class="ticket-info-label">Booking Status</div>
                            <div class="ticket-info-value">@Model.Reservation.Status</div>
                        </div>
                    </div>

                    <div class="ticket-code-panel">
                        <div class="ticket-code-label">Ticket Code</div>
                        <div class="ticket-code-value">@Model.Reservation.TicketCode</div>
                    </div>

                    @if (Model.Reservation.IsCheckedIn && Model.Reservation.CheckedInAt.HasValue)
                    {
                        <div class="alert-info-modern">
                            <i class="bi bi-person-check-fill me-2"></i>
                            Guest already checked in on
                            @Model.Reservation.CheckedInAt.Value.ToLocalTime().ToString("MMM dd, yyyy hh:mm tt")
                        </div>
                    }
                    else if (Model.Reservation.Status == "Cancelled")
                    {
                        <div class="alert-danger-modern mt-3">
                            <i class="bi bi-x-octagon-fill me-2"></i>
                            This booking is cancelled and cannot be checked in.
                        </div>
                    }
                    else if (Model.Reservation.PaymentStatus != "Paid")
                    {
                        <div class="alert-warning-modern mt-3">
                            <i class="bi bi-hourglass-split me-2"></i>
                            This booking cannot be checked in until payment is completed.
                        </div>
                    }
                    else
                    {
                        <form method="post" asp-page-handler="ConfirmCheckIn" class="mt-4">
                            <input type="hidden" asp-for="TicketCode" value="@Model.Reservation.TicketCode" />
                            <button type="submit" class="btn-confirm-checkin">
                                <i class="bi bi-check2-circle me-2"></i>Confirm Guest Check-In
                            </button>
                        </form>
                    }
                }
            </div>
        </div>
    </div>
</div>

