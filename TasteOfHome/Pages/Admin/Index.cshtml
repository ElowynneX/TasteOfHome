@page
@model TasteOfHome.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Admin Dashboard";

    var totalFeedback = Model.FeedbackList.Count;
    var pendingFeedback = Model.FeedbackList.Count(f => f.Status == "Pending");
    var approvedFeedback = Model.FeedbackList.Count(f => f.Status == "Approved");

    var totalHiddenGems = Model.HiddenGemList.Count;
    var pendingHiddenGems = Model.HiddenGemList.Count(h => h.Status == "Pending");
    var approvedHiddenGems = Model.HiddenGemList.Count(h => h.Status == "Approved");

    var totalRestaurants = Model.RestaurantList.Count;
}

@if (TempData["StatusMessage"] != null)
{
    <div class="dashboard-success-alert">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["StatusMessage"]
    </div>
}

<div class="admin-dashboard-page">
    <div class="dashboard-stats-grid">
        <div class="dashboard-stat-card">
            <div class="stat-icon stat-blue">
                <i class="bi bi-chat-left-text-fill"></i>
            </div>
            <div>
                <div class="stat-label">Total Feedback</div>
                <div class="stat-value">@totalFeedback</div>
                <div class="stat-meta">@pendingFeedback pending moderation</div>
            </div>
        </div>

        <div class="dashboard-stat-card">
            <div class="stat-icon stat-green">
                <i class="bi bi-patch-check-fill"></i>
            </div>
            <div>
                <div class="stat-label">Approved Reviews</div>
                <div class="stat-value">@approvedFeedback</div>
                <div class="stat-meta">Visible to public users</div>
            </div>
        </div>

        <div class="dashboard-stat-card">
            <div class="stat-icon stat-purple">
                <i class="bi bi-shop"></i>
            </div>
            <div>
                <div class="stat-label">Restaurants</div>
                <div class="stat-value">@totalRestaurants</div>
                <div class="stat-meta">Currently on platform</div>
            </div>
        </div>

        <div class="dashboard-stat-card">
            <div class="stat-icon stat-orange">
                <i class="bi bi-hourglass-split"></i>
            </div>
            <div>
                <div class="stat-label">Pending Hidden Gems</div>
                <div class="stat-value">@pendingHiddenGems</div>
                <div class="stat-meta">Waiting for review</div>
            </div>
        </div>

        <div class="dashboard-stat-card">
            <div class="stat-icon stat-pink">
                <i class="bi bi-gem"></i>
            </div>
            <div>
                <div class="stat-label">Approved Hidden Gems</div>
                <div class="stat-value">@approvedHiddenGems</div>
                <div class="stat-meta">Published to platform</div>
            </div>
        </div>
    </div>

    <section class="admin-section">
        <div class="admin-section-header">
            <div>
                <h2 class="admin-section-title">Restaurant Management</h2>
                <p class="admin-section-subtitle">Delete one or multiple restaurants from the platform.</p>
            </div>
        </div>

        <div class="admin-panel">
            <form method="post"
                  asp-page-handler="DeleteSelectedRestaurants"
                  onsubmit="return confirm('Are you sure you want to delete the selected restaurants and all related reviews?');">

                @Html.AntiForgeryToken()

                <div class="panel-toolbar">
                    <div class="panel-toolbar-left">
                        <button type="submit" class="admin-btn admin-btn-delete">
                            <i class="bi bi-trash3 me-1"></i> Delete Selected
                        </button>

                        <button type="button" class="admin-btn admin-btn-secondary" onclick="toggleSelectAll(true)">
                            Select All
                        </button>

                        <button type="button" class="admin-btn admin-btn-secondary" onclick="toggleSelectAll(false)">
                            Clear Selection
                        </button>
                    </div>

                    <div class="panel-toolbar-right">
                        <span class="toolbar-count">@Model.RestaurantList.Count restaurant(s)</span>
                    </div>
                </div>

                @if (Model.RestaurantList.Count == 0)
                {
                    <div class="empty-state">
                        <div class="empty-icon"><i class="bi bi-shop-window"></i></div>
                        <h4>No restaurants found</h4>
                        <p>Restaurants will appear here once they are added to the platform.</p>
                    </div>
                }
                else
                {
                    <div class="admin-table-wrap">
                        <table class="admin-table">
                            <thead>
                                <tr>
                                    <th style="width:50px;">
                                        <input type="checkbox" onclick="toggleSelectAll(this.checked)" />
                                    </th>
                                    <th>Name</th>
                                    <th>Cuisine</th>
                                    <th>Location</th>
                                    <th>Rating</th>
                                    <th>Authenticity</th>
                                    <th>Source</th>
                                    <th>Reviews</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var restaurant in Model.RestaurantList)
                                {
                                    <tr>
                                        <td>
                                            <input type="checkbox"
                                                   name="SelectedRestaurantIds"
                                                   value="@restaurant.Id"
                                                   class="restaurant-checkbox" />
                                        </td>
                                        <td>
                                            <div class="restaurant-cell">
                                                <div class="restaurant-avatar">
                                                    @(string.IsNullOrWhiteSpace(restaurant.Name) ? "R" : restaurant.Name.Substring(0, 1).ToUpper())
                                                </div>
                                                <div>
                                                    <span class="item-title">@restaurant.Name</span>
                                                    <span class="item-subtext">Restaurant ID: @restaurant.Id</span>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="data-chip">@restaurant.Cuisine</span>
                                        </td>
                                        <td>@restaurant.Location</td>
                                        <td><span class="metric-pill">@restaurant.Rating</span></td>
                                        <td><span class="metric-pill metric-gold">@restaurant.Authenticity%</span></td>
                                        <td>
                                            <span class="status-pill @(restaurant.Source == "GooglePlaces" ? "status-approved" : "status-pending")">
                                                @(string.IsNullOrWhiteSpace(restaurant.Source) ? "Manual" : restaurant.Source)
                                            </span>
                                        </td>
                                        <td><span class="review-count">@restaurant.NumberOfReviews</span></td>
                                        <td class="text-end">
                                            <div class="action-stack">
                                                <button type="submit"
                                                        class="admin-btn admin-btn-delete"
                                                        formaction="@Url.Page("/Admin/Index", "DeleteRestaurant", new { id = restaurant.Id })"
                                                        formmethod="post"
                                                        onclick="return confirm('Are you sure you want to delete this restaurant and all related reviews?');">
                                                    Delete
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </form>
        </div>
    </section>

    <section class="admin-section">
        <div class="admin-section-header">
            <div>
                <h2 class="admin-section-title">Restaurant Feedback Moderation</h2>
                <p class="admin-section-subtitle">Review authenticity, ratings, and community comments before publishing.</p>
            </div>
        </div>

        <div class="admin-panel">
            @if (Model.FeedbackList.Count == 0)
            {
                <div class="empty-state">
                    <div class="empty-icon"><i class="bi bi-chat-square-text"></i></div>
                    <h4>No feedback records found</h4>
                    <p>Customer feedback will appear here for moderation.</p>
                </div>
            }
            else
            {
                <div class="admin-table-wrap">
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>Restaurant</th>
                                <th>Rating</th>
                                <th>Authenticity</th>
                                <th>Review</th>
                                <th>Status</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.FeedbackList)
                            {
                                var statusClass = item.Status == "Approved"
                                ? "status-approved"
                                : item.Status == "Denied"
                                ? "status-denied"
                                : "status-pending";

                                <tr>
                                    <td>
                                        <span class="item-title">@item.RestaurantName</span>
                                        <span class="item-subtext">Restaurant ID: @item.RestaurantId</span>
                                    </td>
                                    <td><span class="metric-pill">@item.Rating / 5</span></td>
                                    <td><span class="metric-pill metric-gold">@item.Authenticity%</span></td>
                                    <td class="review-text">@item.Review</td>
                                    <td><span class="status-pill @statusClass">@item.Status</span></td>
                                    <td class="text-end">
                                        <div class="action-stack">
                                            @if (item.Status == "Pending")
                                            {
                                                <form method="post" asp-page-handler="Approve" asp-route-id="@item.Id">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="admin-btn admin-btn-approve">Approve</button>
                                                </form>

                                                <form method="post" asp-page-handler="Deny" asp-route-id="@item.Id">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="admin-btn admin-btn-deny">Deny</button>
                                                </form>
                                            }
                                            else
                                            {
                                                <span class="item-subtext">No action available</span>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </section>

    <section class="admin-section">
        <div class="admin-section-header">
            <div>
                <h2 class="admin-section-title">Hidden Gem Submissions</h2>
                <p class="admin-section-subtitle">Approve, reject, or remove community-submitted discoveries.</p>
            </div>
        </div>

        <div class="admin-panel">
            @if (Model.HiddenGemList.Count == 0)
            {
                <div class="empty-state">
                    <div class="empty-icon"><i class="bi bi-gem"></i></div>
                    <h4>No hidden gem submissions found</h4>
                    <p>Community-submitted discoveries will appear here.</p>
                </div>
            }
            else
            {
                <div class="admin-table-wrap">
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>Provider</th>
                                <th>Location</th>
                                <th>Food Type</th>
                                <th>Authenticity</th>
                                <th>Status</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var gem in Model.HiddenGemList)
                            {
                                var statusClass = gem.Status == "Approved"
                                ? "status-approved"
                                : gem.Status == "Denied"
                                ? "status-denied"
                                : "status-pending";

                                <tr>
                                    <td>
                                        <span class="item-title">@gem.ProviderName</span>
                                        <span class="item-subtext">@gem.Description</span>
                                        @if (!string.IsNullOrWhiteSpace(gem.ContactInfo))
                                        {
                                            <span class="item-subtext">Contact: @gem.ContactInfo</span>
                                        }
                                    </td>
                                    <td>@gem.Location</td>
                                    <td><span class="data-chip">@gem.FoodType</span></td>
                                    <td><span class="metric-pill metric-gold">@gem.AuthenticityHint%</span></td>
                                    <td><span class="status-pill @statusClass">@gem.Status</span></td>
                                    <td class="text-end">
                                        <div class="action-stack">
                                            @if (gem.Status == "Pending")
                                            {
                                                <form method="post" asp-page-handler="ApproveHiddenGem" asp-route-id="@gem.Id">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="admin-btn admin-btn-approve">Approve</button>
                                                </form>

                                                <form method="post" asp-page-handler="DenyHiddenGem" asp-route-id="@gem.Id">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="admin-btn admin-btn-deny">Deny</button>
                                                </form>
                                            }

                                            <form method="post" asp-page-handler="DeleteHiddenGem" asp-route-id="@gem.Id">
                                                @Html.AntiForgeryToken()
                                                <button type="submit"
                                                        class="admin-btn admin-btn-delete"
                                                        onclick="return confirm('Are you sure you want to delete this hidden gem?');">
                                                    Delete
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </section>
</div>

<style>
    .admin-dashboard-page {
        padding: 24px;
        color: #eef4ff;
    }

    .dashboard-success-alert {
        background: rgba(25, 135, 84, 0.16);
        border: 1px solid rgba(25, 135, 84, 0.35);
        color: #b8f5d2;
        border-radius: 14px;
        padding: 14px 16px;
        margin-bottom: 20px;
        font-weight: 600;
    }

    .dashboard-stats-grid {
        display: grid;
        grid-template-columns: repeat(5, minmax(0, 1fr));
        gap: 18px;
        margin-bottom: 28px;
    }

    .dashboard-stat-card {
        background: rgba(10, 21, 50, 0.92);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 22px;
        padding: 18px;
        display: flex;
        align-items: center;
        gap: 14px;
        box-shadow: 0 16px 34px rgba(0,0,0,0.2);
    }

    .stat-icon {
        width: 54px;
        height: 54px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        color: white;
        flex-shrink: 0;
    }

    .stat-blue {
        background: linear-gradient(135deg, #3b82f6, #1d4ed8);
    }

    .stat-green {
        background: linear-gradient(135deg, #10b981, #047857);
    }

    .stat-purple {
        background: linear-gradient(135deg, #8b5cf6, #6d28d9);
    }

    .stat-orange {
        background: linear-gradient(135deg, #f59e0b, #d97706);
    }

    .stat-pink {
        background: linear-gradient(135deg, #ec4899, #be185d);
    }

    .stat-label {
        color: #98acd2;
        font-size: 0.88rem;
        margin-bottom: 4px;
    }

    .stat-value {
        color: #fff;
        font-size: 1.6rem;
        font-weight: 900;
        line-height: 1.1;
    }

    .stat-meta {
        color: #9fb2d6;
        font-size: 0.82rem;
        margin-top: 4px;
    }

    .admin-section {
        margin-bottom: 24px;
    }

    .admin-section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 14px;
        margin-bottom: 14px;
        flex-wrap: wrap;
    }

    .admin-section-title {
        color: #fff;
        font-size: 1.6rem;
        font-weight: 800;
        margin: 0 0 6px 0;
    }

    .admin-section-subtitle {
        color: #98acd2;
        margin: 0;
        font-size: 0.95rem;
    }

    .admin-panel {
        background: rgba(10, 21, 50, 0.94);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 24px;
        padding: 20px;
        box-shadow: 0 18px 36px rgba(0,0,0,0.22);
    }

    .panel-toolbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        margin-bottom: 16px;
        flex-wrap: wrap;
    }

    .panel-toolbar-left {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .toolbar-count {
        color: #9fb2d6;
        font-size: 0.9rem;
        font-weight: 600;
    }

    .admin-table-wrap {
        overflow-x: auto;
    }

    .admin-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        color: #e7efff;
    }

        .admin-table thead th {
            color: #8fa4cb;
            border-bottom: 1px solid rgba(255,255,255,0.08);
            font-size: 0.82rem;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            padding: 14px 12px;
            white-space: nowrap;
            background: rgba(255,255,255,0.03);
        }

        .admin-table tbody td {
            padding: 14px 12px;
            border-bottom: 1px solid rgba(255,255,255,0.06);
            vertical-align: middle;
        }

        .admin-table tbody tr:hover {
            background: rgba(255,255,255,0.03);
        }

    .restaurant-cell {
        display: flex;
        align-items: center;
        gap: 12px;
        min-width: 260px;
    }

    .restaurant-avatar {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        background: linear-gradient(135deg, rgba(255,138,0,0.24), rgba(255,77,109,0.18));
        display: flex;
        align-items: center;
        justify-content: center;
        color: #ffcc9c;
        font-weight: 800;
        flex-shrink: 0;
    }

    .item-title {
        display: block;
        color: #fff;
        font-weight: 700;
    }

    .item-subtext {
        display: block;
        color: #8fa4cb;
        font-size: 0.82rem;
        margin-top: 2px;
    }

    .data-chip {
        display: inline-flex;
        align-items: center;
        padding: 6px 10px;
        border-radius: 999px;
        font-size: 0.78rem;
        background: rgba(255,255,255,0.06);
        color: #dce8ff;
        border: 1px solid rgba(255,255,255,0.08);
    }

    .metric-pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 6px 10px;
        border-radius: 999px;
        background: rgba(59, 130, 246, 0.18);
        color: #a9cbff;
        font-weight: 700;
        min-width: 56px;
    }

    .metric-gold {
        background: rgba(245, 158, 11, 0.18);
        color: #ffd37f;
    }

    .status-pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 6px 10px;
        border-radius: 999px;
        font-size: 0.78rem;
        font-weight: 700;
        white-space: nowrap;
    }

    .status-approved {
        background: rgba(25, 135, 84, 0.18);
        color: #8cf0b8;
        border: 1px solid rgba(25, 135, 84, 0.28);
    }

    .status-denied {
        background: rgba(220, 53, 69, 0.18);
        color: #ff9eaa;
        border: 1px solid rgba(220, 53, 69, 0.28);
    }

    .status-pending {
        background: rgba(245, 158, 11, 0.18);
        color: #ffd37f;
        border: 1px solid rgba(245, 158, 11, 0.28);
    }

    .review-count {
        color: #fff;
        font-weight: 700;
    }

    .review-text {
        max-width: 360px;
        color: #e7efff;
    }

    .action-stack {
        display: flex;
        gap: 8px;
        justify-content: flex-end;
        flex-wrap: wrap;
    }

    .admin-btn {
        border: none;
        border-radius: 10px;
        padding: 8px 12px;
        font-weight: 700;
        font-size: 0.85rem;
        cursor: pointer;
        transition: all 0.18s ease;
    }

        .admin-btn:hover {
            transform: translateY(-1px);
        }

    .admin-btn-delete {
        background: rgba(220, 53, 69, 0.18);
        color: #ffb3bd;
        border: 1px solid rgba(220, 53, 69, 0.28);
    }

    .admin-btn-approve {
        background: rgba(16, 185, 129, 0.18);
        color: #9ef0c7;
        border: 1px solid rgba(16, 185, 129, 0.28);
    }

    .admin-btn-deny {
        background: rgba(245, 158, 11, 0.18);
        color: #ffd37f;
        border: 1px solid rgba(245, 158, 11, 0.28);
    }

    .admin-btn-secondary {
        background: rgba(255,255,255,0.06);
        color: #e6eeff;
        border: 1px solid rgba(255,255,255,0.08);
    }

    .empty-state {
        text-align: center;
        padding: 42px 20px;
        color: #bfd0ec;
    }

    .empty-icon {
        width: 72px;
        height: 72px;
        border-radius: 20px;
        margin: 0 auto 16px auto;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255,255,255,0.06);
        font-size: 1.8rem;
        color: #ffb26b;
    }

    @@media (max-width: 1400px) {
        .dashboard-stats-grid {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }
    }

    @@media (max-width: 992px) {
        .dashboard-stats-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 768px) {
        .admin-dashboard-page {
            padding: 16px;
        }

        .dashboard-stats-grid {
            grid-template-columns: 1fr;
        }

        .restaurant-cell {
            min-width: unset;
        }

        .action-stack {
            justify-content: flex-start;
        }
    }
</style>

@section Scripts {
    <script>
        function toggleSelectAll(isChecked) {
            const checkboxes = document.querySelectorAll('.restaurant-checkbox');
            checkboxes.forEach(cb => cb.checked = isChecked);
        }
    </script>
}