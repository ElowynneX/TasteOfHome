@page
@model TasteOfHome.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Admin Dashboard";

    var totalFeedback = Model.FeedbackList.Count;
    var pendingFeedback = Model.FeedbackList.Count(f => f.Status == "Pending");
    var approvedFeedback = Model.FeedbackList.Count(f => f.Status == "Approved");

    var totalHiddenGems = Model.HiddenGemList.Count;
    var pendingHiddenGems = Model.HiddenGemList.Count(h => h.Status == "Pending");
    var approvedHiddenGems = Model.HiddenGemList.Count(h => h.Status == "Approved");

    var totalRestaurants = Model.RestaurantList.Count;
    var importedRestaurants = Model.RestaurantList.Count(r => r.Source == "GooglePlaces");
}

@if (TempData["StatusMessage"] != null)
{
    <div class="admin-alert">
        @TempData["StatusMessage"]
    </div>
}

<div class="stat-grid">
    <div class="stat-card">
        <div class="stat-label">Total Feedback</div>
        <div class="stat-value">@totalFeedback</div>
        <div class="stat-meta">@pendingFeedback pending for moderation</div>
    </div>

    <div class="stat-card">
        <div class="stat-label">Approved Reviews</div>
        <div class="stat-value">@approvedFeedback</div>
        <div class="stat-meta">Visible to public users</div>
    </div>

    <div class="stat-card">
        <div class="stat-label">Total Restaurants</div>
        <div class="stat-value">@totalRestaurants</div>
        <div class="stat-meta">@importedRestaurants imported from Google</div>
    </div>

    <div class="stat-card">
        <div class="stat-label">Approved Hidden Gems</div>
        <div class="stat-value">@approvedHiddenGems</div>
        <div class="stat-meta">Published to the platform</div>
    </div>
</div>

<section class="admin-section">
    <div class="admin-section-header">
        <div>
            <h2 class="admin-section-title">Import Nearby Restaurants</h2>
            <p class="admin-section-subtitle">Fetch real restaurants by region and add them to the platform.</p>
        </div>
    </div>

    <div class="admin-panel p-4">
        <form method="post" asp-page-handler="ImportNearby" class="row g-3">
            @Html.AntiForgeryToken()

            <div class="col-md-9">
                <input asp-for="ImportQuery"
                       class="form-control"
                       placeholder="Example: restaurants in Kitchener Ontario" />
            </div>
            <div class="col-md-3">
                <button type="submit" class="admin-btn admin-btn-approve w-100">
                    Import Restaurants
                </button>
            </div>
        </form>

        <div class="mt-3 text-light">
            Try:
            <span class="metric-pill">restaurants in Waterloo Ontario</span>
            <span class="metric-pill">restaurants in Cambridge Ontario</span>
            <span class="metric-pill">restaurants in Brampton Ontario</span>
            <span class="metric-pill">restaurants in Scarborough Toronto Ontario</span>
        </div>
    </div>
</section>

<section class="admin-section">
    <div class="admin-section-header">
        <div>
            <h2 class="admin-section-title">Restaurant Management</h2>
            <p class="admin-section-subtitle">Delete one or multiple restaurants from the platform.</p>
        </div>
    </div>

    <div class="admin-panel p-4">
        <form method="post"
              asp-page-handler="DeleteSelectedRestaurants"
              onsubmit="return confirm('Are you sure you want to delete the selected restaurants and all related reviews?');">

            @Html.AntiForgeryToken()

            <div class="mb-3 d-flex gap-2 flex-wrap">
                <button type="submit" class="admin-btn admin-btn-delete">
                    Delete Selected
                </button>

                <button type="button" class="admin-btn admin-btn-approve" onclick="toggleSelectAll(true)">
                    Select All
                </button>

                <button type="button" class="admin-btn admin-btn-deny" onclick="toggleSelectAll(false)">
                    Clear Selection
                </button>
            </div>

            @if (Model.RestaurantList.Count == 0)
            {
                <div class="empty-state">
                    No restaurants found.
                </div>
            }
            else
            {
                <div class="admin-table-wrap">
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>
                                    <input type="checkbox" onclick="toggleSelectAll(this.checked)" />
                                </th>
                                <th>Name</th>
                                <th>Cuisine</th>
                                <th>Location</th>
                                <th>Rating</th>
                                <th>Authenticity</th>
                                <th>Source</th>
                                <th>Reviews</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var restaurant in Model.RestaurantList)
                            {
                                <tr>
                                    <td>
                                        <input type="checkbox"
                                               name="SelectedRestaurantIds"
                                               value="@restaurant.Id"
                                               class="restaurant-checkbox" />
                                    </td>
                                    <td>
                                        <span class="item-title">@restaurant.Name</span>
                                        <span class="item-subtext">Restaurant ID: @restaurant.Id</span>
                                    </td>
                                    <td>@restaurant.Cuisine</td>
                                    <td>@restaurant.Location</td>
                                    <td><span class="metric-pill">@restaurant.Rating</span></td>
                                    <td><span class="metric-pill">@restaurant.Authenticity%</span></td>
                                    <td>
                                        <span class="status-pill @(restaurant.Source == "GooglePlaces" ? "status-approved" : "status-pending")">
                                            @(string.IsNullOrWhiteSpace(restaurant.Source) ? "Manual" : restaurant.Source)
                                        </span>
                                    </td>
                                    <td>@restaurant.NumberOfReviews</td>
                                    <td>
                                        <div class="action-stack">
                                            <button type="submit"
                                                    class="admin-btn admin-btn-delete"
                                                    formaction="@Url.Page("/Admin/Index", "DeleteRestaurant", new { id = restaurant.Id })"
                                                    formmethod="post"
                                                    onclick="return confirm('Are you sure you want to delete this restaurant and all related reviews?');">
                                                Delete
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </form>
    </div>
</section>

<section class="admin-section">
    <div class="admin-section-header">
        <div>
            <h2 class="admin-section-title">Restaurant Feedback Moderation</h2>
            <p class="admin-section-subtitle">Review authenticity, ratings, and community comments before publishing.</p>
        </div>
    </div>

    <div class="admin-panel">
        @if (Model.FeedbackList.Count == 0)
        {
            <div class="empty-state">
                No feedback records found.
            </div>
        }
        else
        {
            <div class="admin-table-wrap">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Restaurant</th>
                            <th>Rating</th>
                            <th>Authenticity</th>
                            <th>Review</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.FeedbackList)
                        {
                            var statusClass = item.Status == "Approved"
                            ? "status-approved"
                            : item.Status == "Denied"
                            ? "status-denied"
                            : "status-pending";

                            <tr>
                                <td>
                                    <span class="item-title">@item.RestaurantName</span>
                                    <span class="item-subtext">Restaurant ID: @item.RestaurantId</span>
                                </td>
                                <td><span class="metric-pill">@item.Rating / 5</span></td>
                                <td><span class="metric-pill">@item.Authenticity%</span></td>
                                <td>@item.Review</td>
                                <td><span class="status-pill @statusClass">@item.Status</span></td>
                                <td>
                                    <div class="action-stack">
                                        @if (item.Status == "Pending")
                                        {
                                            <form method="post" asp-page-handler="Approve" asp-route-id="@item.Id">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="admin-btn admin-btn-approve">Approve</button>
                                            </form>

                                            <form method="post" asp-page-handler="Deny" asp-route-id="@item.Id">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="admin-btn admin-btn-deny">Deny</button>
                                            </form>
                                        }
                                        else
                                        {
                                            <span class="item-subtext">No action available</span>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</section>

<section class="admin-section">
    <div class="admin-section-header">
        <div>
            <h2 class="admin-section-title">Hidden Gem Submissions</h2>
            <p class="admin-section-subtitle">Approve, reject, or remove community-submitted discoveries.</p>
        </div>
    </div>

    <div class="admin-panel">
        @if (Model.HiddenGemList.Count == 0)
        {
            <div class="empty-state">
                No hidden gem submissions found.
            </div>
        }
        else
        {
            <div class="admin-table-wrap">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Provider</th>
                            <th>Location</th>
                            <th>Food Type</th>
                            <th>Authenticity</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var gem in Model.HiddenGemList)
                        {
                            var statusClass = gem.Status == "Approved"
                            ? "status-approved"
                            : gem.Status == "Denied"
                            ? "status-denied"
                            : "status-pending";

                            <tr>
                                <td>
                                    <span class="item-title">@gem.ProviderName</span>
                                    <span class="item-subtext">@gem.Description</span>
                                    @if (!string.IsNullOrWhiteSpace(gem.ContactInfo))
                                    {
                                        <span class="item-subtext">Contact: @gem.ContactInfo</span>
                                    }
                                </td>
                                <td>@gem.Location</td>
                                <td>@gem.FoodType</td>
                                <td><span class="metric-pill">@gem.AuthenticityHint%</span></td>
                                <td><span class="status-pill @statusClass">@gem.Status</span></td>
                                <td>
                                    <div class="action-stack">
                                        @if (gem.Status == "Pending")
                                        {
                                            <form method="post" asp-page-handler="ApproveHiddenGem" asp-route-id="@gem.Id">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="admin-btn admin-btn-approve">Approve</button>
                                            </form>

                                            <form method="post" asp-page-handler="DenyHiddenGem" asp-route-id="@gem.Id">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="admin-btn admin-btn-deny">Deny</button>
                                            </form>
                                        }

                                        <form method="post" asp-page-handler="DeleteHiddenGem" asp-route-id="@gem.Id">
                                            @Html.AntiForgeryToken()
                                            <button type="submit"
                                                    class="admin-btn admin-btn-delete"
                                                    onclick="return confirm('Are you sure you want to delete this hidden gem?');">
                                                Delete
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</section>

@section Scripts {
    <script>
        function toggleSelectAll(isChecked) {
            const checkboxes = document.querySelectorAll('.restaurant-checkbox');
            checkboxes.forEach(cb => cb.checked = isChecked);
        }
    </script>
}