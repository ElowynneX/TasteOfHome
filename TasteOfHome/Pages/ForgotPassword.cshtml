@page
@model TasteOfHome.Pages.ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot Password";
}

<style>
    .auth-wrapper {
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 4rem 1rem;
    }

    .auth-card {
        background: white;
        width: 100%;
        max-width: 480px;
        border-radius: 28px;
        padding: 3rem;
        box-shadow: 0 25px 60px rgba(0,0,0,0.08);
        border: 1px solid #f2e4de;
    }

    .auth-header h2 {
        font-size: 1.9rem;
        font-weight: 800;
        margin-bottom: 0.6rem;
    }

    .auth-header p {
        color: #6b6b6b;
        margin-bottom: 2rem;
    }

    .auth-form {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .form-modern {
        display: flex;
        flex-direction: column;
    }

        .form-modern label {
            font-weight: 600;
            margin-bottom: 0.5rem;
        }

        .form-modern input {
            border-radius: 14px;
            border: 1px solid #e4d7d0;
            padding: 0.8rem 1rem;
            font-size: 0.95rem;
            transition: all 0.25s ease;
        }

            .form-modern input:focus {
                outline: none;
                border-color: #ff7a3d;
                box-shadow: 0 0 0 3px rgba(255,122,61,0.15);
            }

    .auth-btn {
        background: linear-gradient(135deg, #ff7a3d, #ff9f66);
        color: white;
        border: none;
        padding: 0.9rem;
        border-radius: 999px;
        font-weight: 700;
        transition: all 0.3s ease;
    }

        .auth-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 30px rgba(255,111,61,0.35);
        }

    .auth-success {
        background: #eafaf1;
        color: #2ecc71;
        padding: 1rem;
        border-radius: 12px;
        margin-bottom: 1.5rem;
    }

    .auth-error {
        background: #fdecea;
        color: #e74c3c;
        padding: 1rem;
        border-radius: 12px;
        margin-bottom: 1.5rem;
    }

    .auth-back-link {
        text-align: center;
        color: #777;
        text-decoration: none;
        font-size: 0.9rem;
    }

        .auth-back-link:hover {
            color: #ff6f3d;
        }
</style>

<div class="auth-wrapper">

    <div class="auth-card">

        <div class="auth-header">
            <h2>Forgot Password</h2>
            <p>Enter your email and we’ll send you a secure reset link.</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.Message))
        {
            <div class="auth-success">
                @Model.Message
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.Error))
        {
            <div class="auth-error">
                @Model.Error
            </div>
        }

        <form method="post" class="auth-form">

            <div class="form-modern">
                <label>Email Address</label>
                <input asp-for="Email" type="email" placeholder="Enter your email" />
            </div>

            <button type="submit" class="auth-btn">
                Send Reset Link
            </button>

            <a asp-page="/Login" class="auth-back-link">
                ← Back to Login
            </a>

        </form>

    </div>

</div>